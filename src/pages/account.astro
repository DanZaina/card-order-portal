---
import Layout from '../layouts/Layout.astro';
import clients from '../data/clients.json';
const clientsJson = JSON.stringify(clients);
---
<Layout title="My Account — Card Order Portal">
  <script id="client-data" type="application/json" set:html={clientsJson}></script>

  <style is:global>
    :root { --ta: #1e293b; --ta-h: #0f172a; --sidebar-bg: #1e293b; }
    #user-avatar  { background-color: var(--ta) !important; }
    #sidebar, #mobile-sidebar-panel { background-color: var(--sidebar-bg); }
    #mobile-topbar { background-color: var(--sidebar-bg); }
    .sidebar-nav-active { background-color: rgba(255,255,255,0.12) !important; }
    .sidebar-nav-item:hover { background-color: rgba(255,255,255,0.08); }
    button svg, a svg { display: block; }
  </style>

  <div class="flex h-screen overflow-hidden bg-gray-50">

    <!-- ── Sidebar (desktop) ── -->
    <div class="hidden lg:flex lg:w-64 lg:flex-col lg:fixed lg:inset-y-0 z-30">
      <div id="sidebar" class="flex grow flex-col overflow-y-auto pb-4">
        <div class="flex h-16 shrink-0 items-center px-6">
          <img src="/logo-landscape-white.png" alt="ION Professional Printing" class="h-7 object-contain" />
        </div>
        <nav class="flex flex-1 flex-col px-6">
          <ul role="list" class="flex flex-1 flex-col gap-y-7">
            <li>
              <ul role="list" class="-mx-2 space-y-1">
                <li>
                  <a href="/order"
                    class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
                    <i data-lucide="credit-card" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
                    Order Cards
                  </a>
                </li>
                <li>
                  <a href="/history"
                    class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
                    <i data-lucide="clock" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
                    Order History
                  </a>
                </li>
                <li>
                  <a href="/settings"
                    class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
                    <i data-lucide="settings" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
                    Settings
                  </a>
                </li>
              </ul>
            </li>
            <li class="-mx-6 mt-auto border-t border-white/10 pt-1 relative">
              <!-- Flyout menu (opens upward) -->
              <div id="user-flyout" class="hidden absolute bottom-full left-2 right-2 mb-1 bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden z-50">
                <a href="/account"
                  class="flex items-center gap-x-3 px-4 py-3 text-sm text-gray-700 bg-gray-50 font-medium transition-colors">
                  <i data-lucide="user" class="w-4 h-4 text-gray-400 shrink-0"></i>
                  My Account
                </a>
                <a href="/settings"
                  class="flex items-center gap-x-3 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                  <i data-lucide="settings" class="w-4 h-4 text-gray-400 shrink-0"></i>
                  Settings
                </a>
                <div class="border-t border-gray-100"></div>
                <button id="nav-logout" type="button"
                  class="w-full flex items-center gap-x-3 px-4 py-3 text-sm text-red-500 hover:bg-red-50 transition-colors">
                  <i data-lucide="log-out" class="w-4 h-4 shrink-0"></i>
                  Sign out
                </button>
              </div>
              <!-- Trigger button -->
              <button id="user-menu-btn" type="button"
                class="w-full flex items-center gap-x-3 px-6 py-3 hover:bg-white/5 transition-colors">
                <div id="user-avatar"
                  class="w-9 h-9 rounded-full text-white flex items-center justify-center text-xs font-bold shrink-0 select-none">
                  <span id="user-initials">?</span>
                </div>
                <div class="min-w-0 flex-1 text-left">
                  <p id="dd-client-name" class="text-sm font-semibold text-white truncate"></p>
                  <p id="dd-email" class="text-xs text-white/50 truncate"></p>
                </div>
                <i data-lucide="chevrons-up-down" class="w-4 h-4 text-white/40 shrink-0"></i>
              </button>
            </li>
          </ul>
        </nav>
      </div>
    </div>

    <!-- ── Mobile top bar ── -->
    <div id="mobile-topbar" class="lg:hidden fixed top-0 left-0 right-0 z-20 flex items-center gap-x-4 px-4 py-3 shadow-sm">
      <button id="mobile-menu-btn" type="button" class="text-white">
        <i data-lucide="menu" class="w-6 h-6"></i>
      </button>
      <img src="/logo-landscape-white.png" alt="ION" class="h-7 object-contain" />
    </div>

    <!-- ── Mobile sidebar overlay ── -->
    <div id="mobile-sidebar-overlay" class="hidden fixed inset-0 z-40 lg:hidden">
      <div id="sidebar-backdrop" class="fixed inset-0 bg-gray-900/80"></div>
      <div id="mobile-sidebar-panel" class="fixed inset-y-0 left-0 flex w-64 flex-col">
        <div class="flex grow flex-col overflow-y-auto pb-4">
          <div class="flex h-16 shrink-0 items-center justify-between px-6">
            <img src="/logo-landscape-white.png" class="h-7 object-contain" />
            <button id="mobile-sidebar-close" type="button" class="text-white/70 hover:text-white">
              <i data-lucide="x" class="w-5 h-5"></i>
            </button>
          </div>
          <nav class="flex flex-col px-6 gap-y-1">
            <a href="/order"
              class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="credit-card" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Order Cards
            </a>
            <a href="/history"
              class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="clock" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Order History
            </a>
            <a href="/settings"
              class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="settings" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Settings
            </a>
            <a href="/account"
              class="sidebar-nav-item sidebar-nav-active group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white">
              <i data-lucide="user" class="w-6 h-6 shrink-0 text-white"></i>
              My Account
            </a>
            <button type="button" id="mobile-nav-logout"
              class="sidebar-nav-item w-full group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="log-out" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Sign out
            </button>
          </nav>
        </div>
      </div>
    </div>

    <!-- ── Main content ── -->
    <div class="flex flex-1 flex-col lg:pl-64">
      <main class="flex-1 overflow-y-auto">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 pt-16 lg:pt-10">

          <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-900">My Account</h1>
            <p class="text-gray-400 mt-1 text-sm">Update your personal information</p>
          </div>

          <!-- Account info -->
          <div class="bg-white rounded-2xl border border-gray-200 divide-y divide-gray-100">

            <div class="px-6 py-5">
              <h2 class="text-sm font-semibold text-gray-700 mb-4">Contact Information</h2>
              <div class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5" for="acct-first-name">First Name</label>
                    <input id="acct-first-name" type="text" placeholder="First name"
                      class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5" for="acct-last-name">Last Name</label>
                    <input id="acct-last-name" type="text" placeholder="Last name"
                      class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5" for="acct-phone">Phone</label>
                  <input id="acct-phone" type="tel" placeholder="(000) 000-0000"
                    class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5" for="acct-email">Email</label>
                  <input id="acct-email" type="email" readonly
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-400 text-sm cursor-not-allowed outline-none" />
                  <p class="text-xs text-gray-400 mt-1">Managed by your administrator</p>
                </div>
              </div>
            </div>

            <div class="px-6 py-5 flex justify-end">
              <button id="account-save"
                class="px-5 py-2.5 rounded-xl bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium transition-colors">
                Save Changes
              </button>
            </div>
          </div>

        </div>
      </main>
    </div>
  </div>

  <script>
    const CLIENT_DATA = JSON.parse(document.getElementById('client-data').textContent);
    let currentUser = null;

    function applyClientTheme(theme) {
      if (!theme) return;
      if (theme.accent)    document.documentElement.style.setProperty('--ta',         theme.accent);
      if (theme.dark)      document.documentElement.style.setProperty('--ta-h',       theme.dark);
      if (theme.sidebarBg) document.documentElement.style.setProperty('--sidebar-bg', theme.sidebarBg);
    }

    function getInitials(name, email) {
      if (name && name.trim())
        return name.trim().split(/\s+/).map(w => w[0]).join('').toUpperCase().slice(0, 2);
      return (email || '?')[0].toUpperCase();
    }

    function initUser(user) {
      if (!user) { window.location.href = '/'; return; }
      currentUser = user;
      const data = CLIENT_DATA[user.email] || {};

      const savedFirst = localStorage.getItem('portal.firstName') || '';
      const savedLast  = localStorage.getItem('portal.lastName') || '';
      const savedPhone = localStorage.getItem('portal.phone') || data.phone || '';

      // Fall back: split stored full name into first/last if new keys not yet set
      if (!savedFirst && !savedLast) {
        const savedName = localStorage.getItem('portal.displayName')
          || data.full_name || user.user_metadata?.full_name || '';
        const parts = savedName.trim().split(/\s+/);
        (document.getElementById('acct-first-name') as HTMLInputElement).value = parts[0] || '';
        (document.getElementById('acct-last-name') as HTMLInputElement).value  = parts.slice(1).join(' ') || '';
      } else {
        (document.getElementById('acct-first-name') as HTMLInputElement).value = savedFirst;
        (document.getElementById('acct-last-name') as HTMLInputElement).value  = savedLast;
      }

      (document.getElementById('acct-phone') as HTMLInputElement).value = savedPhone;
      (document.getElementById('acct-email') as HTMLInputElement).value = user.email || '';

      const displayName = [savedFirst, savedLast].filter(Boolean).join(' ')
        || localStorage.getItem('portal.displayName')
        || data.full_name || '';

      document.getElementById('user-initials').textContent = getInitials(displayName, user.email);
      document.getElementById('dd-email').textContent      = user.email;
      const clientEl = document.getElementById('dd-client-name');
      if (clientEl) clientEl.textContent = data.company || displayName || user.email || '';

      if (data.theme) applyClientTheme(data.theme);
    }

    function getUserFromStorage() {
      try { return JSON.parse(localStorage.getItem('gotrue.user') || 'null'); } catch { return null; }
    }

    document.addEventListener('DOMContentLoaded', () => {
      if (window.lucide) window.lucide.createIcons();

      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => initUser(user || getUserFromStorage()));
      } else {
        initUser(getUserFromStorage());
      }

      // Mobile sidebar
      const mobileOverlay      = document.getElementById('mobile-sidebar-overlay');
      const openMobileSidebar  = () => mobileOverlay?.classList.remove('hidden');
      const closeMobileSidebar = () => mobileOverlay?.classList.add('hidden');
      document.getElementById('mobile-menu-btn')?.addEventListener('click', openMobileSidebar);
      document.getElementById('mobile-sidebar-close')?.addEventListener('click', closeMobileSidebar);
      document.getElementById('sidebar-backdrop')?.addEventListener('click', closeMobileSidebar);

      // User flyout
      const userFlyout  = document.getElementById('user-flyout');
      const userMenuBtn = document.getElementById('user-menu-btn');
      userMenuBtn?.addEventListener('click', (e) => { e.stopPropagation(); userFlyout?.classList.toggle('hidden'); });
      document.addEventListener('click', () => userFlyout?.classList.add('hidden'));
      userFlyout?.addEventListener('click', (e) => e.stopPropagation());

      // Logout
      const doLogout = () => {
        localStorage.removeItem('gotrue.user');
        localStorage.removeItem('portal.displayName');
        window.netlifyIdentity?.logout();
        window.location.href = '/';
      };
      document.getElementById('nav-logout')?.addEventListener('click', doLogout);
      document.getElementById('mobile-nav-logout')?.addEventListener('click', doLogout);

      // Save
      document.getElementById('account-save')?.addEventListener('click', () => {
        const firstName = (document.getElementById('acct-first-name') as HTMLInputElement).value.trim();
        const lastName  = (document.getElementById('acct-last-name') as HTMLInputElement).value.trim();
        const phone     = (document.getElementById('acct-phone') as HTMLInputElement).value.trim();

        localStorage.setItem('portal.firstName', firstName);
        localStorage.setItem('portal.lastName',  lastName);
        if (phone) localStorage.setItem('portal.phone', phone);

        const displayName = [firstName, lastName].filter(Boolean).join(' ');
        if (displayName) {
          localStorage.setItem('portal.displayName', displayName);
          document.getElementById('user-initials').textContent = getInitials(displayName, currentUser?.email);
          const clientEl = document.getElementById('dd-client-name');
          if (clientEl && clientEl.textContent !== (CLIENT_DATA[currentUser?.email]?.company || '')) {
            clientEl.textContent = displayName;
          }
        }

        const btn = document.getElementById('account-save');
        if (btn) { btn.textContent = 'Saved!'; setTimeout(() => btn.textContent = 'Save Changes', 1500); }
      });
    });
  </script>
</Layout>
