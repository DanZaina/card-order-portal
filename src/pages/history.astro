---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import clients from '../data/clients.json';
const clientsJson = JSON.stringify(clients);
---
<Layout title="Order History — ION Portal" bodyClass="dash">
  <script id="client-data" type="application/json" set:html={clientsJson}></script>

  <style is:global>
    button svg, a svg { display: block; }
  </style>

  <Sidebar activePage="history" />

  <div class="md:ml-64 pt-14 md:pt-0 min-h-screen flex flex-col">
    <main class="flex-1 flex flex-col justify-center p-6 max-w-5xl w-full mx-auto">

      <!-- Header -->
      <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold" style="color:var(--ds-text);">Order History</h1>
          <p class="text-sm mt-1" style="color:var(--ds-text-muted);">All previously submitted card orders</p>
        </div>
        <a href="/order" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white transition-colors"
          style="background:var(--ta,#0ea5e9);">
          <i data-lucide="plus" style="width:16px;height:16px;"></i>
          New Order
        </a>
      </div>

      <!-- Loading -->
      <div id="history-loading" class="flex items-center justify-center py-20">
        <div class="text-sm" style="color:var(--ds-text-dim2);">Loading…</div>
      </div>

      <!-- Empty state -->
      <div id="history-empty" class="hidden flex flex-col items-center justify-center py-20">
        <i data-lucide="inbox" style="width:40px;height:40px;color:var(--ds-border);margin-bottom:16px;display:block;"></i>
        <p class="font-medium" style="color:var(--ds-text-dim);">No orders yet</p>
        <p class="text-sm mt-1" style="color:var(--ds-text-dim2);">Orders you submit will appear here</p>
        <a href="/order" class="mt-6 px-4 py-2 rounded-xl text-sm font-semibold text-white"
          style="background:var(--ta,#0ea5e9);">
          Place your first order
        </a>
      </div>

      <!-- Order list -->
      <div id="history-container" class="hidden space-y-5">

        <!-- Stats row -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-2">
          <div class="rounded-2xl p-5" style="background:var(--ds-surface);border:1px solid var(--ds-border);">
            <p class="text-xs font-semibold uppercase tracking-wider" style="color:var(--ds-text-dim2);">Total Orders</p>
            <p id="stat-total" class="mt-1 text-2xl font-bold" style="color:var(--ds-text);">0</p>
          </div>
          <div class="rounded-2xl p-5" style="background:var(--ds-surface);border:1px solid var(--ds-border);">
            <p class="text-xs font-semibold uppercase tracking-wider" style="color:var(--ds-text-dim2);">Latest Order</p>
            <p id="stat-latest" class="mt-1 text-sm font-semibold leading-tight" style="color:var(--ds-text);">—</p>
          </div>
          <div class="rounded-2xl p-5 hidden sm:block" style="background:var(--ds-surface);border:1px solid var(--ds-border);">
            <p class="text-xs font-semibold uppercase tracking-wider" style="color:var(--ds-text-dim2);">Total Cards</p>
            <p id="stat-cards" class="mt-1 text-2xl font-bold" style="color:var(--ds-text);">0</p>
          </div>
        </div>

        <!-- Table -->
        <div class="rounded-2xl overflow-hidden" style="background:var(--ds-surface);border:1px solid var(--ds-border);">
          <div class="overflow-x-auto">
            <table class="min-w-full">
              <thead>
                <tr style="border-bottom:1px solid var(--ds-border);">
                  <th class="hist-th text-left">Name</th>
                  <th class="hist-th text-left hidden sm:table-cell">Title</th>
                  <th class="hist-th text-left hidden md:table-cell">Date</th>
                  <th class="hist-th text-left hidden lg:table-cell">Qty</th>
                  <th class="hist-th text-right">Actions</th>
                </tr>
              </thead>
              <tbody id="history-tbody"></tbody>
            </table>
          </div>
        </div>

        <!-- Pagination -->
        <div id="pagination" class="hidden flex items-center justify-between px-1 py-2">
          <p id="page-info" class="text-sm" style="color:var(--ds-text-dim);"></p>
          <div class="flex gap-2">
            <button id="page-prev" type="button"
              class="px-4 py-2 text-sm font-medium rounded-xl transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
              style="border:1px solid var(--ds-border);color:var(--ds-text-muted);background:transparent;">
              Previous
            </button>
            <button id="page-next" type="button"
              class="px-4 py-2 text-sm font-medium rounded-xl transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
              style="border:1px solid var(--ds-border);color:var(--ds-text-muted);background:transparent;">
              Next
            </button>
          </div>
        </div>

      </div>
    </main>
  </div>

</Layout>

<style>
  .hist-th {
    padding: 12px 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--ds-text-dim2);
  }
</style>

<script>
  const PAGE_SIZE = 25;
  let currentPage = 0;

  const CLIENT_DATA = JSON.parse(document.getElementById('client-data').textContent);

  function applyClientTheme(theme) {
    if (!theme) return;
    if (theme.accent)    document.documentElement.style.setProperty('--ta',    theme.accent);
    if (theme.dark)      document.documentElement.style.setProperty('--ta-h',  theme.dark);
  }

  function initUser(user) {
    if (!user) { window.location.href = '/'; return; }
    const data = CLIENT_DATA[user.email] || {};
    if (data.theme) applyClientTheme(data.theme);
  }

  function getUserFromStorage() {
    try { return JSON.parse(localStorage.getItem('gotrue.user') || 'null'); } catch { return null; }
  }

  function getOrders() {
    try { return JSON.parse(localStorage.getItem('portal.orders') || '[]'); } catch { return []; }
  }

  function deleteOrder(id) {
    const orders = getOrders().filter(o => o.id !== id);
    localStorage.setItem('portal.orders', JSON.stringify(orders));
  }

  function reorder(order) {
    localStorage.setItem('portal.draftOrder', JSON.stringify(order));
    window.location.href = '/order';
  }

  function updateStats(orders) {
    document.getElementById('stat-total').textContent = orders.length;
    const latest = orders[0];
    document.getElementById('stat-latest').textContent = latest
      ? (latest.name || 'Unnamed') + (latest.date ? ` · ${latest.date}` : '')
      : '—';
    const totalCards = orders.reduce((sum, o) => sum + Number(o.quantity || 0), 0);
    document.getElementById('stat-cards').textContent = totalCards.toLocaleString();
  }

  function renderPage() {
    const orders     = getOrders();
    const total      = orders.length;
    const totalPages = Math.ceil(total / PAGE_SIZE);
    const start      = currentPage * PAGE_SIZE;
    const pageOrders = orders.slice(start, start + PAGE_SIZE);

    const tbody = document.getElementById('history-tbody');
    tbody.innerHTML = '';

    pageOrders.forEach(order => {
      const tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid var(--ds-surface-2)';
      tr.innerHTML = `
        <td class="px-5 py-4">
          <p class="text-sm font-medium truncate max-w-[160px]" style="color:var(--ds-text);">${order.name || 'Unnamed'}</p>
          ${order.company ? `<p class="text-xs truncate max-w-[160px]" style="color:var(--ds-text-dim);">${order.company}</p>` : ''}
        </td>
        <td class="px-5 py-4 hidden sm:table-cell">
          <p class="text-sm truncate max-w-[140px]" style="color:var(--ds-text-muted);">${order.title || '—'}</p>
        </td>
        <td class="px-5 py-4 hidden md:table-cell">
          <p class="text-sm" style="color:var(--ds-text-muted);">${order.date || '—'}</p>
        </td>
        <td class="px-5 py-4 hidden lg:table-cell">
          <span style="font-size:11px;font-weight:600;padding:3px 10px;border-radius:99px;background:var(--ds-badge-muted-bg);color:var(--ds-badge-muted-txt);">
            ${Number(order.quantity || 500).toLocaleString()}
          </span>
        </td>
        <td class="px-5 py-4 text-right">
          <div class="flex items-center justify-end gap-2">
            <button data-reorder="${order.id}" type="button"
              class="text-xs font-medium px-3 py-1.5 rounded-lg text-white transition-colors"
              style="background:var(--ta,#0ea5e9);">
              Reorder
            </button>
            <button data-delete="${order.id}" type="button"
              class="text-xs font-medium px-3 py-1.5 rounded-lg transition-colors"
              style="border:1px solid var(--ds-border);color:var(--ds-text-dim);background:transparent;">
              Delete
            </button>
          </div>
        </td>`;

      tr.querySelector('[data-reorder]')?.addEventListener('click', () => reorder(order));
      tr.querySelector('[data-delete]')?.addEventListener('click', () => {
        if (confirm(`Delete order for ${order.name || 'this person'}?`)) {
          deleteOrder(order.id);
          renderPage();
          updateStats(getOrders());
        }
      });

      tbody.appendChild(tr);
    });

    // Pagination
    const paginationEl = document.getElementById('pagination');
    const prevBtn      = document.getElementById('page-prev');
    const nextBtn      = document.getElementById('page-next');
    const pageInfo     = document.getElementById('page-info');

    if (totalPages > 1) {
      paginationEl?.classList.remove('hidden');
      const from = start + 1;
      const to   = Math.min(start + PAGE_SIZE, total);
      if (pageInfo) pageInfo.textContent = `Showing ${from}–${to} of ${total} orders`;
      if (prevBtn) prevBtn.disabled = currentPage === 0;
      if (nextBtn) nextBtn.disabled = currentPage >= totalPages - 1;
    } else {
      paginationEl?.classList.add('hidden');
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (window.lucide) window.lucide.createIcons();

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', (user) => initUser(user || getUserFromStorage()));
    } else {
      initUser(getUserFromStorage());
    }

    // Pagination controls
    document.getElementById('page-prev')?.addEventListener('click', () => {
      if (currentPage > 0) { currentPage--; renderPage(); }
    });
    document.getElementById('page-next')?.addEventListener('click', () => {
      const total = getOrders().length;
      if ((currentPage + 1) * PAGE_SIZE < total) { currentPage++; renderPage(); }
    });

    // Load orders
    const orders = getOrders();
    document.getElementById('history-loading')?.classList.add('hidden');

    if (orders.length === 0) {
      document.getElementById('history-empty')?.classList.remove('hidden');
    } else {
      document.getElementById('history-container')?.classList.remove('hidden');
      updateStats(orders);
      renderPage();
    }
  });
</script>
