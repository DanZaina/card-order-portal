---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Card Order Portal — Login">
  <div class="min-h-screen flex items-center justify-center" style="background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 50%, #e0f2fe 100%);">
    <div class="w-full max-w-sm px-6">

      <!-- Login card -->
      <div class="bg-white rounded-3xl shadow-xl px-10 py-12 text-center">

        <!-- Icon -->
        <div class="flex items-center justify-center w-20 h-20 rounded-full mx-auto mb-6" style="background-color: var(--sky-500);">
          <img src="/leaf.svg" alt="" class="w-11 h-11 object-contain" style="filter: brightness(0) invert(1);" />
        </div>

        <!-- Heading -->
        <h1 class="text-2xl font-bold text-gray-900 mb-1">Client Login</h1>
        <p class="text-gray-400 text-sm mb-8">Sign in to place your business card order</p>

        <!-- Sign in state -->
        <div id="login-message">
          <button id="login-btn" class="btn">
            Sign In
          </button>
        </div>

        <!-- Logged in state -->
        <div id="logged-in-message" class="hidden">
          <div class="flex items-center justify-center gap-2 mb-3" style="color: var(--sky-600);">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="font-medium text-sm">You're signed in</span>
          </div>
          <p id="user-email" class="text-gray-400 text-sm mb-6"></p>
          <a href="/order" class="btn">
            Go to Order Form →
          </a>
          <button id="logout-btn" class="btn btn-ghost mt-2 text-sm">
            Sign out
          </button>
        </div>

        <p class="text-gray-400 text-xs mt-8">
          Don't have an account? <span class="font-medium" style="color: var(--sky-500);">Contact us for access.</span>
        </p>
      </div>

    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const loginBtn = document.getElementById('login-btn');
      const logoutBtn = document.getElementById('logout-btn');
      const loginMessage = document.getElementById('login-message');
      const loggedInMessage = document.getElementById('logged-in-message');
      const userEmail = document.getElementById('user-email');

      function updateUI(user) {
        if (user) {
          loginMessage.classList.add('hidden');
          loggedInMessage.classList.remove('hidden');
          userEmail.textContent = user.email;
        } else {
          loginMessage.classList.remove('hidden');
          loggedInMessage.classList.add('hidden');
        }
      }

      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', updateUI);
        window.netlifyIdentity.on('logout', () => updateUI(null));
      }

      loginBtn?.addEventListener('click', () => {
        window.netlifyIdentity?.open('login');
      });

      logoutBtn?.addEventListener('click', () => {
        window.netlifyIdentity?.logout();
      });
    });
  </script>
</Layout>
