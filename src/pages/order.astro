---
import Layout from '../layouts/Layout.astro';
import clients from '../data/clients.json';
const clientsJson = JSON.stringify(clients);
---
<Layout title="Place Your Order — Card Order Portal">
  <!-- Client data (server-injected, read by auth script) -->
  <script id="client-data" type="application/json" set:html={clientsJson}></script>

  <!-- Theme custom properties — overridden by JS on load -->
  <style is:global>
    :root { --ta: #1e293b; --ta-h: #0f172a; --sidebar-bg: #1e293b; }
    #user-avatar  { background-color: var(--ta) !important; }
    #submit-btn   { background-color: var(--ta) !important; }
    #submit-btn:hover { background-color: var(--ta-h) !important; }
    #c-accent-bar { background-color: var(--ta) !important; }
    #sidebar, #mobile-sidebar-panel { background-color: var(--sidebar-bg); }
    #mobile-topbar { background-color: var(--sidebar-bg); }
    .sidebar-nav-active { background-color: rgba(255,255,255,0.12) !important; }
    .sidebar-nav-item:hover { background-color: rgba(255,255,255,0.08); }
    button svg, a svg { display: block; }
    select { -webkit-appearance: none; -moz-appearance: none; appearance: none; }
  </style>

  <div class="flex h-screen overflow-hidden bg-gray-50">

    <!-- ── Sidebar (desktop) ── -->
    <div class="hidden lg:flex lg:w-64 lg:flex-col lg:fixed lg:inset-y-0 z-30">
      <div id="sidebar" class="flex grow flex-col overflow-y-auto pb-4">

        <!-- Logo -->
        <div class="flex h-16 shrink-0 items-center px-6">
          <img src="/logo-landscape-white.png" alt="ION Professional Printing" class="h-7 object-contain" />
        </div>

        <nav class="flex flex-1 flex-col px-6">
          <ul role="list" class="flex flex-1 flex-col gap-y-7">

            <!-- Main nav -->
            <li>
              <ul role="list" class="-mx-2 space-y-1">
                <li>
                  <a href="/order"
                    class="sidebar-nav-item sidebar-nav-active group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white">
                    <i data-lucide="credit-card" class="w-6 h-6 shrink-0 text-white"></i>
                    Order Cards
                  </a>
                </li>
                <li>
                  <a href="/history"
                    class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
                    <i data-lucide="clock" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
                    Order History
                  </a>
                </li>
              </ul>
            </li>

            <!-- Bottom: client name + user flyout -->
            <li class="-mx-6 mt-auto border-t border-white/10 pt-1 relative">
              <!-- Flyout menu (opens upward) -->
              <div id="user-flyout" class="hidden absolute bottom-full left-2 right-2 mb-1 bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden z-50">
                <button id="nav-account-btn" type="button"
                  class="w-full flex items-center gap-x-3 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                  <i data-lucide="user" class="w-4 h-4 text-gray-400 shrink-0"></i>
                  My Account
                </button>
                <a href="/settings"
                  class="flex items-center gap-x-3 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                  <i data-lucide="settings" class="w-4 h-4 text-gray-400 shrink-0"></i>
                  Settings
                </a>
                <div class="border-t border-gray-100"></div>
                <button id="nav-logout" type="button"
                  class="w-full flex items-center gap-x-3 px-4 py-3 text-sm text-red-500 hover:bg-red-50 transition-colors">
                  <i data-lucide="log-out" class="w-4 h-4 shrink-0"></i>
                  Sign out
                </button>
              </div>
              <!-- Trigger button -->
              <button id="user-menu-btn" type="button"
                class="w-full flex items-center gap-x-3 px-6 py-3 hover:bg-white/5 transition-colors">
                <div id="user-avatar"
                  class="w-9 h-9 rounded-full text-white flex items-center justify-center text-xs font-bold shrink-0 select-none">
                  <span id="user-initials">?</span>
                </div>
                <div class="min-w-0 flex-1 text-left">
                  <p id="dd-client-name" class="text-sm font-semibold text-white truncate"></p>
                  <p id="dd-email" class="text-xs text-white/50 truncate"></p>
                </div>
                <i data-lucide="chevrons-up-down" class="w-4 h-4 text-white/40 shrink-0"></i>
              </button>
              <!-- Hidden spans keep IDs working in JS -->
              <span id="nav-name" class="hidden"></span>
              <span id="dd-name" class="hidden"></span>
            </li>

          </ul>
        </nav>
      </div>
    </div>

    <!-- ── Mobile top bar ── -->
    <div id="mobile-topbar" class="lg:hidden fixed top-0 left-0 right-0 z-20 flex items-center gap-x-4 px-4 py-3 shadow-sm">
      <button id="mobile-menu-btn" type="button" class="text-white">
        <i data-lucide="menu" class="w-6 h-6"></i>
      </button>
      <img src="/logo-landscape-white.png" alt="ION" class="h-7 object-contain" />
    </div>

    <!-- ── Mobile sidebar overlay ── -->
    <div id="mobile-sidebar-overlay" class="hidden fixed inset-0 z-40 lg:hidden">
      <div id="sidebar-backdrop" class="fixed inset-0 bg-gray-900/80"></div>
      <div id="mobile-sidebar-panel" class="fixed inset-y-0 left-0 flex w-64 flex-col">
        <div class="flex grow flex-col overflow-y-auto pb-4">
          <div class="flex h-16 shrink-0 items-center justify-between px-6">
            <img src="/logo-landscape-white.png" class="h-7 object-contain" />
            <button id="mobile-sidebar-close" type="button" class="text-white/70 hover:text-white">
              <i data-lucide="x" class="w-5 h-5"></i>
            </button>
          </div>
          <nav class="flex flex-col px-6 gap-y-1">
            <a href="/order"
              class="sidebar-nav-item sidebar-nav-active group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white">
              <i data-lucide="credit-card" class="w-6 h-6 shrink-0 text-white"></i>
              Order Cards
            </a>
            <a href="/history"
              class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="clock" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Order History
            </a>
            <button type="button" id="mobile-nav-account-btn"
              class="sidebar-nav-item w-full group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="user" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              My Account
            </button>
            <a href="/settings"
              class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="settings" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Settings
            </a>
            <button type="button" id="mobile-nav-logout"
              class="sidebar-nav-item w-full group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="log-out" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Sign out
            </button>
          </nav>
        </div>
      </div>
    </div>

    <!-- ── Main content ── -->
    <div class="flex flex-1 flex-col lg:pl-64">
      <main class="flex-1 overflow-y-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 pt-16 lg:pt-10">
      <div class="mb-10">
        <h1 class="text-2xl font-bold text-gray-900">Order Business Cards</h1>
        <p class="text-gray-400 mt-1">Fill in your details and see a live preview of your card</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

        <!-- ── LEFT: Form ── -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">

          <!-- Form header with refresh -->
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-lg font-semibold text-gray-900">Card Details</h2>
            <button id="refresh-btn" type="button" title="Reset to defaults"
              class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-gray-700 transition-colors px-2.5 py-1.5 rounded-lg hover:bg-gray-100">
              <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i>
              Reset
            </button>
          </div>

          <!-- Hidden Netlify form for detection -->
          <form name="business-card-order" netlify netlify-honeypot="bot-field" hidden>
            <input type="text" name="name" />
            <input type="text" name="job_title" />
            <input type="text" name="company" />
            <input type="email" name="email" />
            <input type="tel" name="phone" />
            <input type="text" name="extension" />
            <input type="tel" name="cell" />
            <input type="text" name="address" />
            <input type="text" name="card_style" />
            <input type="text" name="accent_color" />
            <input type="number" name="quantity" />
            <textarea name="notes"></textarea>
            <input type="text" name="ordered_by" />
            <textarea name="additional_people"></textarea>
          </form>

          <!-- Visible form -->
          <form id="order-form" class="space-y-6" novalidate>
            <input type="text" name="bot-field" class="hidden" aria-hidden="true" />
            <!-- Hidden fields populated by prefill for preview + submission -->
            <input type="hidden" id="f-company" name="company" />
            <input type="hidden" id="f-website" name="website" />

            <!-- Name + Title -->
            <div id="row-name" data-field-row class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-name">
                  Full Name <span class="text-red-500">*</span>
                </label>
                <input id="f-name" name="name" type="text" placeholder="First Last Name"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-title">
                  Job Title <span class="text-red-500">*</span>
                </label>
                <input id="f-title" name="job_title" type="text" placeholder="Enter Title"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
            </div>

            <!-- Email -->
            <div id="row-email" data-field-row>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-email">
                Email <span class="text-red-500">*</span>
              </label>
              <input id="f-email" name="email" type="email" placeholder="jane@company.com"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
            </div>

            <!-- Phone / Ext / Cell -->
            <div id="row-phone-ext-cell" data-field-row class="grid grid-cols-2 sm:grid-cols-3 gap-5">
              <div class="col-span-2 sm:col-span-1">
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-phone">Phone</label>
                <input id="f-phone" name="phone" type="tel" placeholder="(705) 526-1344"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-extension">Ext.</label>
                <input id="f-extension" name="extension" type="text" placeholder="000" inputmode="numeric"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-cell">Cell</label>
                <input id="f-cell" name="cell" type="tel" placeholder="(000) 000-0000" inputmode="numeric"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
            </div>

            <!-- Address -->
            <div id="row-website-address" data-field-row>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-address">Address</label>
              <input id="f-address" name="address" type="text" placeholder="947 Jones Road, Midland, ON"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
            </div>

            <input type="hidden" id="f-style" name="card_style" value="classic" />

            <!-- Divider -->
            <div class="border-t border-gray-100 pt-1"></div>

            <!-- Quantity -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-qty">Quantity</label>
                <div class="relative">
                  <select id="f-qty" name="quantity"
                    class="w-full px-4 py-3 pr-10 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white">
                    <option value="250">250 cards</option>
                    <option value="500" selected>500 cards</option>
                    <option value="1000">1,000 cards</option>
                    <option value="2000">2,000 cards</option>
                    <option value="5000">5,000 cards</option>
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                    <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
                  </div>
                </div>
              </div>
            </div>

            <!-- Notes -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-notes">Notes / Special Instructions</label>
              <textarea id="f-notes" name="notes" rows="3"
                placeholder="Any special requests, logo notes, paper finish preferences…"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm resize-none"></textarea>
            </div>

            <!-- Additional people -->
            <div class="border-t border-gray-100 pt-5">
              <div class="flex items-center justify-between mb-3">
                <div>
                  <p class="text-sm font-medium text-gray-700">Additional people</p>
                  <p class="text-xs text-gray-400 mt-0.5">Ordering cards for multiple people?</p>
                </div>
                <button type="button" id="add-person-btn"
                  class="flex items-center gap-1.5 text-xs font-medium text-gray-500 hover:text-gray-800 px-2.5 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors">
                  <i data-lucide="user-plus" class="w-3.5 h-3.5"></i>
                  Add person
                </button>
              </div>
              <div id="extra-people-list" class="space-y-2"></div>
            </div>

            <!-- Error message -->
            <div id="form-error" class="hidden text-red-600 text-sm bg-red-50 rounded-xl px-4 py-3"></div>

            <button type="submit" id="submit-btn"
              class="w-full py-3 px-6 bg-gray-900 hover:bg-gray-700 text-white text-sm font-semibold rounded-xl transition-colors duration-200 disabled:opacity-60">
              <span id="submit-text">Submit Order</span>
              <span id="submit-loading" class="hidden">Submitting…</span>
            </button>
          </form>
        </div>

        <!-- ── RIGHT: Live Preview ── -->
        <div class="lg:sticky lg:top-8 space-y-6">

          <div>
            <h2 class="text-lg font-semibold text-gray-900 mb-5">Live Preview</h2>

            <!-- Card preview — 3.5" × 2" aspect ratio -->
            <div class="w-full" style="perspective: 1000px;">
              <div id="card-preview"
                class="relative w-full rounded-2xl overflow-hidden shadow-2xl transition-all duration-300"
                style="aspect-ratio: 3.5 / 2;">

                <!-- SVG template preview (shown when client has card_template) -->
                <div id="svg-preview" class="hidden absolute inset-0 bg-white">
                  <!-- SVG injected here by JS -->
                </div>

                <!-- Classic style -->
                <div id="style-classic" class="card-style absolute inset-0 bg-white flex">
                  <div id="c-accent-bar" class="w-2 bg-slate-900 shrink-0"></div>
                  <div class="flex-1 flex flex-col justify-between p-7">
                    <div>
                      <div id="c-name" class="text-xl font-bold text-gray-900 leading-tight">Your Name</div>
                      <div id="c-title" class="text-sm text-gray-500 mt-0.5">Job Title</div>
                    </div>
                    <div>
                      <div id="c-company" class="text-base font-semibold text-gray-800 mb-3">Company Name</div>
                      <div class="space-y-1.5 text-xs text-gray-500">
                        <div id="c-email-row" class="flex items-center gap-1.5">
                          <i data-lucide="mail" class="w-3 h-3 shrink-0"></i>
                          <span id="c-email">email@company.com</span>
                        </div>
                        <div id="c-phone-row" class="flex items-center gap-1.5">
                          <i data-lucide="phone" class="w-3 h-3 shrink-0"></i>
                          <span id="c-phone">+1 (555) 000-0000</span>
                        </div>
                        <div id="c-website-row" class="flex items-center gap-1.5">
                          <i data-lucide="globe" class="w-3 h-3 shrink-0"></i>
                          <span id="c-website">www.company.com</span>
                        </div>
                        <div id="c-address-row" class="flex items-center gap-1.5">
                          <i data-lucide="map-pin" class="w-3 h-3 shrink-0"></i>
                          <span id="c-address"></span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Dark style -->
                <div id="style-dark" class="card-style absolute inset-0 bg-gray-950 hidden flex">
                  <div id="d-accent-bar" class="w-2 bg-white shrink-0"></div>
                  <div class="flex-1 flex flex-col justify-between p-7">
                    <div>
                      <div id="d-name" class="text-xl font-bold text-white leading-tight">Your Name</div>
                      <div id="d-title" class="text-sm text-gray-400 mt-0.5">Job Title</div>
                    </div>
                    <div>
                      <div id="d-company" class="text-base font-semibold text-gray-200 mb-3">Company Name</div>
                      <div class="space-y-1.5 text-xs text-gray-400">
                        <div id="d-email-row" class="flex items-center gap-1.5">
                          <i data-lucide="mail" class="w-3 h-3 shrink-0"></i>
                          <span id="d-email">email@company.com</span>
                        </div>
                        <div id="d-phone-row" class="flex items-center gap-1.5">
                          <i data-lucide="phone" class="w-3 h-3 shrink-0"></i>
                          <span id="d-phone">+1 (555) 000-0000</span>
                        </div>
                        <div id="d-website-row" class="flex items-center gap-1.5">
                          <i data-lucide="globe" class="w-3 h-3 shrink-0"></i>
                          <span id="d-website">www.company.com</span>
                        </div>
                        <div id="d-address-row" class="flex items-center gap-1.5">
                          <i data-lucide="map-pin" class="w-3 h-3 shrink-0"></i>
                          <span id="d-address"></span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Branded style -->
                <div id="style-branded" class="card-style absolute inset-0 hidden flex flex-col justify-between p-7"
                  style="background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);">
                  <div>
                    <div id="b-name" class="text-xl font-bold text-white leading-tight">Your Name</div>
                    <div id="b-title" class="text-sm text-white/70 mt-0.5">Job Title</div>
                  </div>
                  <div>
                    <div id="b-company" class="text-base font-semibold text-white mb-3">Company Name</div>
                    <div class="space-y-1.5 text-xs text-white/80">
                      <div id="b-email-row" class="flex items-center gap-1.5">
                        <i data-lucide="mail" class="w-3 h-3 shrink-0"></i>
                        <span id="b-email">email@company.com</span>
                      </div>
                      <div id="b-phone-row" class="flex items-center gap-1.5">
                        <i data-lucide="phone" class="w-3 h-3 shrink-0"></i>
                        <span id="b-phone">+1 (555) 000-0000</span>
                      </div>
                      <div id="b-website-row" class="flex items-center gap-1.5">
                        <i data-lucide="globe" class="w-3 h-3 shrink-0"></i>
                        <span id="b-website">www.company.com</span>
                      </div>
                      <div id="b-address-row" class="flex items-center gap-1.5">
                        <i data-lucide="map-pin" class="w-3 h-3 shrink-0"></i>
                        <span id="b-address"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <p class="text-xs text-gray-400 mt-3 text-center">Preview is approximate — final design may vary slightly</p>
          </div>

          <!-- Order summary -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <h3 class="text-sm font-semibold text-gray-700 mb-4">Order Summary</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between gap-3">
                <dt class="text-gray-400 shrink-0">Name</dt>
                <dd id="summary-name" class="font-medium text-gray-900 text-right truncate">—</dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-gray-400 shrink-0">Title</dt>
                <dd id="summary-title" class="font-medium text-gray-900 text-right truncate">—</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-400">Quantity</dt>
                <dd id="summary-qty" class="font-medium text-gray-900">500 cards</dd>
              </div>
            </dl>
          </div>
        </div>

      </div>
        </div>
      </main>
    </div>
  </div>

  <!-- ── Account modal ── -->
  <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 overflow-y-auto" style="max-height: 90vh;">
      <!-- Header -->
      <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-gray-100">
        <h3 class="text-base font-semibold text-gray-900">My Account</h3>
        <button id="edit-modal-close" class="text-gray-400 hover:text-gray-600 transition-colors">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      <!-- Details section -->
      <div class="px-6 py-6 space-y-4">
        <!-- Email: preset/readonly -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="acct-email">Email</label>
          <input id="acct-email" type="email" readonly
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-400 text-sm cursor-not-allowed outline-none" />
          <p class="text-xs text-gray-400 mt-1">Managed by your administrator</p>
        </div>
        <!-- Display name -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="edit-display-name">Full Name</label>
          <input id="edit-display-name" type="text" placeholder="Your name"
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
        </div>
        <!-- Phone -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="acct-phone">Phone</label>
          <input id="acct-phone" type="tel" placeholder="(000) 000-0000"
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
        </div>
        <div class="flex gap-3 pt-2">
          <button id="edit-modal-cancel"
            class="flex-1 py-2.5 px-4 rounded-xl border border-gray-200 text-sm text-gray-600 hover:bg-gray-50 transition-colors">
            Cancel
          </button>
          <button id="edit-modal-save"
            class="flex-1 py-2.5 px-4 rounded-xl bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium transition-colors">
            Save
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Per-client theme ──
    function applyClientTheme(theme) {
      if (!theme) return;
      if (theme.accent)    document.documentElement.style.setProperty('--ta',         theme.accent);
      if (theme.dark)      document.documentElement.style.setProperty('--ta-h',       theme.dark);
      if (theme.sidebarBg) document.documentElement.style.setProperty('--sidebar-bg', theme.sidebarBg);
    }

    // ── Auth + pre-populate from clients.json ──
    const CLIENT_DATA = JSON.parse(document.getElementById('client-data').textContent);

    let currentUser = null;

    const FIELD_ROWS = {
      name:      'row-name',
      title:     'row-name',
      email:     'row-email',
      phone:     'row-phone-ext-cell',
      extension: 'row-phone-ext-cell',
      cell:      'row-phone-ext-cell',
      website:   'row-website-address',
      address:   'row-website-address',
    };

    function prefill(email) {
      const data = CLIENT_DATA[email] || {};
      const allowedFields = data.fields || ['name','title','email','phone','extension','cell','website','address'];
      const lockedFields  = data.locked || [];

      const set = (id, val) => {
        const el = document.getElementById(id);
        if (!el) return;
        if (val !== undefined && val !== null) {
          el.value = val;
          el.dispatchEvent(new Event('input'));
        }
        const fieldKey = id.replace('f-', '');
        if (lockedFields.includes(fieldKey)) {
          el.readOnly = true;
          el.classList.add('bg-gray-50', 'text-gray-500', 'cursor-not-allowed');
        }
      };

      set('f-name',      data.full_name  || '');
      set('f-title',     data.job_title  || '');
      set('f-company',   data.company    || '');
      set('f-email',     data.email      || email || '');
      set('f-phone',     data.phone      || '');
      set('f-extension', data.extension  || '');
      set('f-cell',      data.cell       || '');
      set('f-address',   data.address    || '');
      set('f-website',   data.website    || '');

      const visibleRows = new Set(allowedFields.map(f => FIELD_ROWS[f]).filter(Boolean));
      document.querySelectorAll('[data-field-row]').forEach(row => {
        row.style.display = visibleRows.has(row.id) ? '' : 'none';
      });
    }

    function getInitials(name, email) {
      if (name && name.trim()) {
        return name.trim().split(/\s+/).map(w => w[0]).join('').toUpperCase().slice(0, 2);
      }
      return (email || '?')[0].toUpperCase();
    }

    function updateDisplayName(name, email) {
      const initials = getInitials(name, email);
      document.getElementById('user-initials').textContent = initials;
      document.getElementById('nav-name').textContent      = name || email || '';
      document.getElementById('dd-name').textContent       = name || email || '';
      const nameField = document.getElementById('f-name');
      if (nameField && !nameField.readOnly && name) {
        nameField.value = name;
        nameField.dispatchEvent(new Event('input'));
      }
    }

    function updateClientLabel(clientName, email) {
      const el = document.getElementById('dd-client-name');
      if (el) el.textContent = clientName || email || '';
    }

    function initUser(user) {
      if (!user) { window.location.href = '/'; return; }
      currentUser = user;
      const data = CLIENT_DATA[user.email] || {};
      const savedName   = localStorage.getItem('portal.displayName');
      const displayName = savedName || data.full_name || user.user_metadata?.full_name || '';
      updateDisplayName(displayName, user.email);
      document.getElementById('dd-email').textContent = user.email;
      updateClientLabel(data.company || displayName, user.email);

      // Apply client-specific theme before prefill so colors are live
      if (data.theme) applyClientTheme(data.theme);

      prefill(user.email);
      if (savedName) {
        const nameField = document.getElementById('f-name');
        if (nameField && !nameField.readOnly) {
          nameField.value = savedName;
          nameField.dispatchEvent(new Event('input'));
        }
      }
      // Load client-specific SVG card template if available
      if (data.card_template) {
        const tryLoad = (attempts = 0) => {
          if (window._portal?.loadSvgTemplate) {
            window._portal.loadSvgTemplate(data.card_template);
          } else if (attempts < 10) {
            setTimeout(() => tryLoad(attempts + 1), 50);
          }
        };
        tryLoad();
      }
      // Load draft order if coming from history page
      const draft = localStorage.getItem('portal.draftOrder');
      if (draft) {
        localStorage.removeItem('portal.draftOrder');
        try { loadOrder(JSON.parse(draft)); } catch {}
      }
    }

    function getUserFromStorage() {
      try { return JSON.parse(localStorage.getItem('gotrue.user') || 'null'); } catch { return null; }
    }

    // ── Title case ──
    function toTitleCase(str: string): string {
      return str.replace(/\S+/g, w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase());
    }

    // ── Cell phone formatting: digits → (XXX) XXX-XXXX ──
    function formatCellPhone(raw: string): string {
      const d = raw.replace(/\D/g, '').slice(0, 10);
      if (d.length < 4)  return d.length ? `(${d}` : '';
      if (d.length < 7)  return `(${d.slice(0,3)}) ${d.slice(3)}`;
      return `(${d.slice(0,3)}) ${d.slice(3,6)}-${d.slice(6)}`;
    }

    // ── Extra people (max 5) ──
    const MAX_PEOPLE = 5;

    function updateAddBtn() {
      const addBtn = document.getElementById('add-person-btn');
      if (!addBtn) return;
      const count = document.querySelectorAll('#extra-people-list [data-person]').length;
      addBtn.style.display = count >= MAX_PEOPLE ? 'none' : '';
    }

    function renumberPeople() {
      document.querySelectorAll('#extra-people-list [data-person]').forEach((row, i) => {
        const label = row.querySelector('.person-num');
        if (label) label.textContent = String(i + 2);
      });
    }

    function addExtraPerson(defaults: { name?: string; title?: string; email?: string; phone?: string; extension?: string; cell?: string; address?: string } = {}) {
      const list = document.getElementById('extra-people-list');
      if (!list) return;
      if (list.querySelectorAll('[data-person]').length >= MAX_PEOPLE) return;

      const num = list.querySelectorAll('[data-person]').length + 2;
      const id  = `person-${Date.now()}`;
      const row = document.createElement('div');
      row.dataset.person = id;
      row.className = 'border border-gray-200 rounded-2xl p-5 bg-gray-50 space-y-4';
      row.innerHTML = `
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold text-gray-700">Person <span class="person-num">${num}</span></p>
          <button type="button" data-remove="${id}"
            class="text-gray-300 hover:text-red-400 transition-colors p-1 rounded-lg hover:bg-red-50">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input type="text" placeholder="Full Name" value="${defaults.name || ''}"
            class="person-name w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white" />
          <input type="text" placeholder="Job Title" value="${defaults.title || ''}"
            class="person-title w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white" />
        </div>
        <input type="email" placeholder="Email" value="${defaults.email || ''}"
          class="person-email w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white" />
        <div class="grid grid-cols-3 gap-4">
          <input type="tel" placeholder="Phone" value="${defaults.phone || ''}"
            class="person-phone w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white" />
          <input type="text" placeholder="Ext." value="${defaults.extension || ''}" inputmode="numeric"
            class="person-ext w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white" />
          <input type="tel" placeholder="Cell" value="${defaults.cell || ''}" inputmode="numeric"
            class="person-cell w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white" />
        </div>
        <input type="text" placeholder="Address" value="${defaults.address || ''}"
          class="person-address w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white" />`;
      row.querySelector('[data-remove]')?.addEventListener('click', () => {
        row.remove();
        updateAddBtn();
        renumberPeople();
      });
      list.appendChild(row);
      updateAddBtn();
      (row.querySelector('.person-name') as HTMLInputElement | null)?.focus();
    }

    function clearExtraPeople() {
      const list = document.getElementById('extra-people-list');
      if (list) list.innerHTML = '';
      updateAddBtn();
    }

    function getExtraPeople() {
      return Array.from(document.querySelectorAll('#extra-people-list [data-person]')).map(row => ({
        name:      (row.querySelector('.person-name')    as HTMLInputElement | null)?.value.trim()  || '',
        title:     (row.querySelector('.person-title')   as HTMLInputElement | null)?.value.trim()  || '',
        email:     (row.querySelector('.person-email')   as HTMLInputElement | null)?.value.trim()  || '',
        phone:     (row.querySelector('.person-phone')   as HTMLInputElement | null)?.value.trim()  || '',
        extension: (row.querySelector('.person-ext')     as HTMLInputElement | null)?.value.trim()  || '',
        cell:      (row.querySelector('.person-cell')    as HTMLInputElement | null)?.value.trim()  || '',
        address:   (row.querySelector('.person-address') as HTMLInputElement | null)?.value.trim()  || '',
      })).filter(p => p.name);
    }

    // ── Order history ──
    function getOrders() {
      try { return JSON.parse(localStorage.getItem('portal.orders') || '[]'); } catch { return []; }
    }

    function saveOrder(orderData) {
      const orders = getOrders();
      orders.unshift({ id: Date.now(), date: new Date().toLocaleDateString(), ...orderData });
      localStorage.setItem('portal.orders', JSON.stringify(orders.slice(0, 200))); // keep last 200
    }

    function loadOrder(order) {
      const setField = (id, val) => {
        const el = document.getElementById(id);
        if (el && !el.readOnly && val !== undefined) {
          el.value = val;
          el.dispatchEvent(new Event('input'));
        }
      };
      setField('f-name',      order.name);
      setField('f-title',     order.title);
      setField('f-email',     order.email);
      setField('f-phone',     order.phone);
      setField('f-extension', order.extension);
      setField('f-cell',      order.cell);
      setField('f-address',   order.address);
      setField('f-notes',     order.notes);
      setField('f-qty',       order.quantity);

      clearExtraPeople();
      (order.extra || []).forEach(p => addExtraPerson(p));

      document.getElementById('edit-modal')?.classList.add('hidden');
    }

    document.addEventListener('DOMContentLoaded', () => {
      if (window.lucide) window.lucide.createIcons();

      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => initUser(user || getUserFromStorage()));
      } else {
        initUser(getUserFromStorage());
      }

      // ── Mobile sidebar ──
      const mobileOverlay = document.getElementById('mobile-sidebar-overlay');
      const openMobileSidebar  = () => mobileOverlay?.classList.remove('hidden');
      const closeMobileSidebar = () => mobileOverlay?.classList.add('hidden');
      document.getElementById('mobile-menu-btn')?.addEventListener('click', openMobileSidebar);
      document.getElementById('mobile-sidebar-close')?.addEventListener('click', closeMobileSidebar);
      document.getElementById('sidebar-backdrop')?.addEventListener('click', closeMobileSidebar);

      // ── User flyout menu ──
      const userFlyout  = document.getElementById('user-flyout');
      const userMenuBtn = document.getElementById('user-menu-btn');
      userMenuBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        userFlyout?.classList.toggle('hidden');
      });
      document.addEventListener('click', () => userFlyout?.classList.add('hidden'));
      userFlyout?.addEventListener('click', (e) => e.stopPropagation());

      // ── Account modal ──
      const editModal = document.getElementById('edit-modal');

      const openEditModal = () => {
        closeMobileSidebar();
        userFlyout?.classList.add('hidden');
        const saved = localStorage.getItem('portal.displayName')
          || (currentUser ? (CLIENT_DATA[currentUser.email]?.full_name || '') : '');
        (document.getElementById('edit-display-name') as HTMLInputElement).value = saved;
        (document.getElementById('acct-email') as HTMLInputElement).value = currentUser?.email || '';
        (document.getElementById('acct-phone') as HTMLInputElement).value =
          localStorage.getItem('portal.phone') || (currentUser ? (CLIENT_DATA[currentUser.email]?.phone || '') : '');
        editModal?.classList.remove('hidden');
        setTimeout(() => document.getElementById('edit-display-name')?.focus(), 50);
      };
      document.getElementById('nav-account-btn')?.addEventListener('click', openEditModal);
      document.getElementById('mobile-nav-account-btn')?.addEventListener('click', openEditModal);

      const closeModal = () => editModal?.classList.add('hidden');
      document.getElementById('edit-modal-close')?.addEventListener('click', closeModal);
      document.getElementById('edit-modal-cancel')?.addEventListener('click', closeModal);
      editModal?.addEventListener('click', (e) => { if (e.target === editModal) closeModal(); });

      document.getElementById('edit-modal-save')?.addEventListener('click', () => {
        const name  = (document.getElementById('edit-display-name') as HTMLInputElement).value.trim();
        const phone = (document.getElementById('acct-phone') as HTMLInputElement).value.trim();
        if (name) {
          localStorage.setItem('portal.displayName', name);
          updateDisplayName(name, currentUser?.email);
        }
        if (phone) localStorage.setItem('portal.phone', phone);
        closeModal();
      });

      document.getElementById('edit-display-name')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') document.getElementById('edit-modal-save')?.click();
        if (e.key === 'Escape') closeModal();
      });

      const doLogout = () => {
        localStorage.removeItem('gotrue.user');
        localStorage.removeItem('portal.displayName');
        window.netlifyIdentity?.logout();
        window.location.href = '/';
      };
      document.getElementById('nav-logout')?.addEventListener('click', doLogout);
      document.getElementById('mobile-nav-logout')?.addEventListener('click', doLogout);

      // ── Refresh / reset ──
      document.getElementById('refresh-btn')?.addEventListener('click', () => {
        if (!currentUser) return;
        const notesEl = document.getElementById('f-notes');
        if (notesEl) notesEl.value = '';
        clearExtraPeople();
        prefill(currentUser.email);
        const btn = document.getElementById('refresh-btn');
        btn.classList.add('text-green-600');
        setTimeout(() => btn.classList.remove('text-green-600'), 800);
      });

      // ── Title case on name blur ──
      document.getElementById('f-name')?.addEventListener('blur', (e) => {
        const input = e.target as HTMLInputElement;
        const titled = toTitleCase(input.value);
        if (titled !== input.value) {
          input.value = titled;
          input.dispatchEvent(new Event('input'));
        }
      });

      // ── Extension: digits only ──
      document.getElementById('f-extension')?.addEventListener('input', (e) => {
        const input = e.target as HTMLInputElement;
        const clean = input.value.replace(/\D/g, '');
        if (clean !== input.value) input.value = clean;
      });

      // ── Cell: digits only, auto-format as (XXX) XXX-XXXX ──
      document.getElementById('f-cell')?.addEventListener('input', (e) => {
        const input = e.target as HTMLInputElement;
        const formatted = formatCellPhone(input.value);
        if (formatted !== input.value) {
          input.value = formatted;
          input.dispatchEvent(new Event('input'));
        }
      });

      // ── Add person (max 1) ──
      document.getElementById('add-person-btn')?.addEventListener('click', () => addExtraPerson());
    });

    // Expose to submission script (separate Astro module scope)
    window._portal = { getExtraPeople, saveOrder, clearExtraPeople };
  </script>

  <script>
    // ── Live Preview ──
    const fields = {
      name:      document.getElementById('f-name'),
      title:     document.getElementById('f-title'),
      company:   document.getElementById('f-company'),
      email:     document.getElementById('f-email'),
      phone:     document.getElementById('f-phone'),
      extension: document.getElementById('f-extension'),
      cell:      document.getElementById('f-cell'),
      website:   document.getElementById('f-website'),
      address:   document.getElementById('f-address'),
      qty:       document.getElementById('f-qty'),
    };

    const placeholders = {
      name:    'Your Name',
      title:   'Job Title',
      company: 'Company Name',
      email:   'email@company.com',
      phone:   '+1 (555) 000-0000',
      website: 'www.company.com',
      address: '',
    };

    let currentStyle = 'classic';
    let svgTemplateHTML: string | null = null; // cached raw SVG markup

    // ── SVG template preview ──
    async function loadSvgTemplate(url: string) {
      try {
        const res = await fetch(url);
        if (!res.ok) return;
        svgTemplateHTML = await res.text();
        const container = document.getElementById('svg-preview');
        if (container) {
          container.innerHTML = svgTemplateHTML;
          // Make the SVG fill its container
          const svg = container.querySelector('svg');
          if (svg) {
            svg.style.width  = '100%';
            svg.style.height = '100%';
          }
          container.classList.remove('hidden');
          // Hide the generic HTML card styles
          document.querySelectorAll('.card-style').forEach(el => el.style.display = 'none');
        }
        updateSvgPreview();
      } catch (e) {
        console.warn('SVG template load failed, using generic preview', e);
      }
    }

    function svgSet(id: string, text: string, fallback = '') {
      const el = document.getElementById('svg-preview')?.querySelector(`#${id}`);
      if (!el) return;
      el.textContent = text || fallback;
      el.setAttribute('visibility', (text || fallback) ? 'visible' : 'hidden');
    }

    function updateSvgPreview() {
      if (!svgTemplateHTML) return;
      const v = (id: string) => (fields[id as keyof typeof fields] as HTMLInputElement | null)?.value?.trim() || '';

      svgSet('svg-name',  v('name'),  'First Last Name');
      svgSet('svg-title', v('title'), 'Enter Title');

      // e : email
      const email = v('email');
      svgSet('svg-email', email ? `e : ${email}` : '', '');

      // t : phone  x  ext
      const phone = v('phone');
      const ext   = v('extension');
      svgSet('svg-phone', phone ? `t : ${phone}${ext ? `  x ${ext}` : ''}` : '', '');

      // c : cell (hidden if empty)
      const cell = v('cell');
      svgSet('svg-cell', cell ? `c : ${cell}` : '', '');
    }

    // ── Generic HTML preview ──
    function updatePreview() {
      const vals = {
        name:    fields.name?.value    || placeholders.name,
        title:   fields.title?.value   || placeholders.title,
        company: fields.company?.value || placeholders.company,
        email:   fields.email?.value   || placeholders.email,
        phone:   fields.phone?.value   || placeholders.phone,
        website: fields.website?.value || placeholders.website,
        address: fields.address?.value || '',
      };

      ['c','d','b'].forEach(prefix => {
        const set  = (id: string, val: string)       => { const el = document.getElementById(id); if (el) el.textContent = val; };
        const show = (id: string, visible: boolean)  => { const el = document.getElementById(id); if (el) el.style.display = visible ? '' : 'none'; };
        set(`${prefix}-name`,    vals.name);
        set(`${prefix}-title`,   vals.title);
        set(`${prefix}-company`, vals.company);
        set(`${prefix}-email`,   vals.email);
        set(`${prefix}-phone`,   vals.phone);
        set(`${prefix}-website`, vals.website);
        set(`${prefix}-address`, vals.address);
        show(`${prefix}-website-row`, !!vals.website);
        show(`${prefix}-address-row`, !!vals.address);
      });

      if (svgTemplateHTML) updateSvgPreview();

      const summaryQty   = document.getElementById('summary-qty');
      const summaryName  = document.getElementById('summary-name');
      const summaryTitle = document.getElementById('summary-title');
      if (summaryQty)   summaryQty.textContent   = `${Number(fields.qty?.value || 500).toLocaleString()} cards`;
      if (summaryName)  summaryName.textContent   = fields.name?.value?.trim()  || '—';
      if (summaryTitle) summaryTitle.textContent  = fields.title?.value?.trim() || '—';
    }

    // Wire up all form inputs
    Object.values(fields).forEach(el => {
      if (el) el.addEventListener('input', updatePreview);
    });

    updatePreview();

    // Expose so auth script can trigger SVG load after user is resolved
    window._portal = window._portal || {};
    window._portal.loadSvgTemplate = loadSvgTemplate;
  </script>

  <script>
    // ── Form submission to Netlify Forms ──
    document.getElementById('order-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn     = document.getElementById('submit-btn')     as HTMLButtonElement | null;
      const submitText    = document.getElementById('submit-text')    as HTMLElement | null;
      const submitLoading = document.getElementById('submit-loading') as HTMLElement | null;
      const errorDiv      = document.getElementById('form-error')     as HTMLElement | null;

      const required = ['f-name','f-title','f-email'];
      const missing  = required.filter(id => !document.getElementById(id)?.value.trim());
      if (missing.length) {
        if (errorDiv) { errorDiv.textContent = 'Please fill in all required fields.'; errorDiv.classList.remove('hidden'); }
        return;
      }
      errorDiv?.classList.add('hidden');

      const storedUser = (() => { try { return JSON.parse(localStorage.getItem('gotrue.user') || '{}'); } catch { return {}; } })();
      const user = window.netlifyIdentity?.currentUser?.() as { email?: string } | null | undefined;
      const orderedBy = user?.email || storedUser.email || 'unknown';

      const nameVal      = document.getElementById('f-name')?.value      || '';
      const titleVal     = document.getElementById('f-title')?.value     || '';
      const companyVal   = document.getElementById('f-company')?.value   || '';
      const emailVal     = document.getElementById('f-email')?.value     || '';
      const phoneVal     = document.getElementById('f-phone')?.value     || '';
      const extensionVal = document.getElementById('f-extension')?.value || '';
      const cellVal      = document.getElementById('f-cell')?.value      || '';
      const addressVal   = document.getElementById('f-address')?.value   || '';
      const styleVal     = document.getElementById('f-style')?.value     || 'classic';
      const accentVal    = document.getElementById('f-accent')?.value    || '';
      const qtyVal       = document.getElementById('f-qty')?.value       || '500';
      const notesVal     = document.getElementById('f-notes')?.value     || '';
      const extraPeople  = window._portal?.getExtraPeople?.() ?? [];

      const formData = new FormData();
      formData.append('form-name',          'business-card-order');
      formData.append('name',               nameVal);
      formData.append('job_title',          titleVal);
      formData.append('company',            companyVal);
      formData.append('email',              emailVal);
      formData.append('phone',              phoneVal);
      formData.append('extension',          extensionVal);
      formData.append('cell',               cellVal);
      formData.append('address',            addressVal);
      formData.append('card_style',         styleVal);
      formData.append('accent_color',       accentVal);
      formData.append('quantity',           qtyVal);
      formData.append('notes',              notesVal);
      formData.append('ordered_by',         orderedBy);
      formData.append('additional_people',  JSON.stringify(extraPeople));

      if (submitBtn)     submitBtn.disabled = true;
      submitText?.classList.add('hidden');
      submitLoading?.classList.remove('hidden');

      try {
        const response = await fetch('/', { method: 'POST', body: formData });
        if (response.ok) {
          // Save one history entry per person
          if (window._portal?.saveOrder) {
            const shared = { company: companyVal, quantity: qtyVal, notes: notesVal };
            window._portal.saveOrder({
              name: nameVal, title: titleVal, email: emailVal,
              phone: phoneVal, extension: extensionVal, cell: cellVal,
              address: addressVal, ...shared,
            });
            extraPeople.forEach(p => {
              window._portal.saveOrder({ ...shared, ...p });
            });
          }
          // Reset form state before redirect
          const notesEl = document.getElementById('f-notes') as HTMLInputElement | null;
          if (notesEl) notesEl.value = '';
          window._portal?.clearExtraPeople?.();
          window.location.href = '/success';
        } else {
          throw new Error(`Server returned ${response.status}`);
        }
      } catch (err) {
        if (errorDiv) { errorDiv.textContent = 'Something went wrong. Please try again or contact us directly.'; errorDiv.classList.remove('hidden'); }
        if (submitBtn)  submitBtn.disabled = false;
        submitText?.classList.remove('hidden');
        submitLoading?.classList.add('hidden');
      }
    });
  </script>
</Layout>
