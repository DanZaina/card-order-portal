---
import Layout from '../layouts/Layout.astro';
import clients from '../data/clients.json';
const clientsJson = JSON.stringify(clients);
---
<Layout title="Place Your Order — Card Order Portal">
  <!-- Client data (server-injected, read by auth script) -->
  <script id="client-data" type="application/json" set:html={clientsJson}></script>

  <div class="min-h-screen bg-gray-50">

    <!-- ── Top nav ── -->
    <nav class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between">
      <div class="flex items-center">
        <img src="/logo-landscape.png" alt="ION Professional Printing" class="h-8 object-contain" />
      </div>

      <!-- User dropdown -->
      <div class="relative" id="user-menu-container">
        <button id="user-menu-btn"
          class="flex items-center gap-2.5 rounded-xl px-3 py-2 hover:bg-gray-100 transition-colors">
          <div id="user-avatar"
            class="w-8 h-8 rounded-full bg-slate-800 text-white flex items-center justify-center text-xs font-bold shrink-0 select-none">
            <span id="user-initials">?</span>
          </div>
          <span id="nav-name" class="hidden sm:block text-sm font-medium text-gray-700 max-w-[160px] truncate"></span>
          <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400 shrink-0"></i>
        </button>

        <!-- Dropdown panel -->
        <div id="user-dropdown"
          class="hidden absolute right-0 top-full mt-1 w-56 bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden z-50">
          <div class="px-4 py-3 border-b border-gray-100">
            <p id="dd-name" class="text-sm font-semibold text-gray-900 truncate"></p>
            <p id="dd-email" class="text-xs text-gray-400 truncate mt-0.5"></p>
          </div>
          <div class="py-1">
            <button id="dd-edit-btn"
              class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
              <i data-lucide="user-pen" class="w-4 h-4 text-gray-400 shrink-0"></i>
              Edit my details
            </button>
            <button id="nav-logout"
              class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors">
              <i data-lucide="log-out" class="w-4 h-4 shrink-0"></i>
              Sign out
            </button>
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="mb-10">
        <h1 class="text-2xl font-bold text-gray-900">Order Business Cards</h1>
        <p class="text-gray-400 mt-1">Fill in your details and see a live preview of your card</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

        <!-- ── LEFT: Form ── -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">

          <!-- Form header with refresh -->
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-lg font-semibold text-gray-900">Card Details</h2>
            <button id="refresh-btn" type="button" title="Reset to defaults"
              class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-gray-700 transition-colors px-2.5 py-1.5 rounded-lg hover:bg-gray-100">
              <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i>
              Reset
            </button>
          </div>

          <!-- Hidden Netlify form for detection -->
          <form name="business-card-order" netlify netlify-honeypot="bot-field" hidden>
            <input type="text" name="name" />
            <input type="text" name="job_title" />
            <input type="text" name="company" />
            <input type="email" name="email" />
            <input type="tel" name="phone" />
            <input type="text" name="extension" />
            <input type="tel" name="cell" />
            <input type="text" name="address" />
            <input type="text" name="card_style" />
            <input type="text" name="accent_color" />
            <input type="number" name="quantity" />
            <textarea name="notes"></textarea>
            <input type="text" name="ordered_by" />
          </form>

          <!-- Visible form -->
          <form id="order-form" class="space-y-6" novalidate>
            <input type="text" name="bot-field" class="hidden" aria-hidden="true" />
            <!-- Hidden fields populated by prefill for preview + submission -->
            <input type="hidden" id="f-company" name="company" />
            <input type="hidden" id="f-website" name="website" />

            <!-- Name + Title -->
            <div id="row-name" data-field-row class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-name">
                  Full Name <span class="text-red-500">*</span>
                </label>
                <input id="f-name" name="name" type="text" placeholder="Jane Smith"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-title">
                  Job Title <span class="text-red-500">*</span>
                </label>
                <input id="f-title" name="job_title" type="text" placeholder="Marketing Director"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
            </div>

            <!-- Email -->
            <div id="row-email" data-field-row>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-email">
                Email <span class="text-red-500">*</span>
              </label>
              <input id="f-email" name="email" type="email" placeholder="jane@company.com"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
            </div>

            <!-- Phone / Ext / Cell -->
            <div id="row-phone-ext-cell" data-field-row class="grid grid-cols-2 sm:grid-cols-3 gap-5">
              <div class="col-span-2 sm:col-span-1">
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-phone">Phone</label>
                <input id="f-phone" name="phone" type="tel" placeholder="(705) 526-1344"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-extension">Ext.</label>
                <input id="f-extension" name="extension" type="text" placeholder="000"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-cell">Cell</label>
                <input id="f-cell" name="cell" type="tel" placeholder="(705) 000-0000"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
              </div>
            </div>

            <!-- Address -->
            <div id="row-website-address" data-field-row>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-address">Address</label>
              <input id="f-address" name="address" type="text" placeholder="947 Jones Road, Midland, ON"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
            </div>

            <input type="hidden" id="f-style" name="card_style" value="classic" />

            <!-- Divider -->
            <div class="border-t border-gray-100 pt-1"></div>

            <!-- Quantity -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-qty">Quantity</label>
                <select id="f-qty" name="quantity"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white">
                  <option value="250">250 cards</option>
                  <option value="500" selected>500 cards</option>
                  <option value="1000">1,000 cards</option>
                  <option value="2000">2,000 cards</option>
                  <option value="5000">5,000 cards</option>
                </select>
              </div>
            </div>

            <!-- Notes -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="f-notes">Notes / Special Instructions</label>
              <textarea id="f-notes" name="notes" rows="3"
                placeholder="Any special requests, logo notes, paper finish preferences…"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm resize-none"></textarea>
            </div>

            <!-- Error message -->
            <div id="form-error" class="hidden text-red-600 text-sm bg-red-50 rounded-xl px-4 py-3"></div>

            <button type="submit" id="submit-btn"
              class="w-full py-3 px-6 bg-gray-900 hover:bg-gray-700 text-white text-sm font-semibold rounded-xl transition-colors duration-200 disabled:opacity-60">
              <span id="submit-text">Submit Order</span>
              <span id="submit-loading" class="hidden">Submitting…</span>
            </button>
          </form>
        </div>

        <!-- ── RIGHT: Live Preview ── -->
        <div class="lg:sticky lg:top-8 space-y-6">

          <div>
            <h2 class="text-lg font-semibold text-gray-900 mb-5">Live Preview</h2>

            <!-- Card preview — 3.5" × 2" aspect ratio -->
            <div class="w-full" style="perspective: 1000px;">
              <div id="card-preview"
                class="relative w-full rounded-2xl overflow-hidden shadow-2xl transition-all duration-300"
                style="aspect-ratio: 3.5 / 2;">

                <!-- Classic style -->
                <div id="style-classic" class="card-style absolute inset-0 bg-white flex">
                  <div id="c-accent-bar" class="w-2 bg-slate-900 shrink-0"></div>
                  <div class="flex-1 flex flex-col justify-between p-7">
                    <div>
                      <div id="c-name" class="text-xl font-bold text-gray-900 leading-tight">Your Name</div>
                      <div id="c-title" class="text-sm text-gray-500 mt-0.5">Job Title</div>
                    </div>
                    <div>
                      <div id="c-company" class="text-base font-semibold text-gray-800 mb-3">Company Name</div>
                      <div class="space-y-1.5 text-xs text-gray-500">
                        <div id="c-email-row" class="flex items-center gap-1.5">
                          <i data-lucide="mail" class="w-3 h-3 shrink-0"></i>
                          <span id="c-email">email@company.com</span>
                        </div>
                        <div id="c-phone-row" class="flex items-center gap-1.5">
                          <i data-lucide="phone" class="w-3 h-3 shrink-0"></i>
                          <span id="c-phone">+1 (555) 000-0000</span>
                        </div>
                        <div id="c-website-row" class="flex items-center gap-1.5">
                          <i data-lucide="globe" class="w-3 h-3 shrink-0"></i>
                          <span id="c-website">www.company.com</span>
                        </div>
                        <div id="c-address-row" class="flex items-center gap-1.5">
                          <i data-lucide="map-pin" class="w-3 h-3 shrink-0"></i>
                          <span id="c-address"></span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Dark style -->
                <div id="style-dark" class="card-style absolute inset-0 bg-gray-950 hidden flex">
                  <div id="d-accent-bar" class="w-2 bg-white shrink-0"></div>
                  <div class="flex-1 flex flex-col justify-between p-7">
                    <div>
                      <div id="d-name" class="text-xl font-bold text-white leading-tight">Your Name</div>
                      <div id="d-title" class="text-sm text-gray-400 mt-0.5">Job Title</div>
                    </div>
                    <div>
                      <div id="d-company" class="text-base font-semibold text-gray-200 mb-3">Company Name</div>
                      <div class="space-y-1.5 text-xs text-gray-400">
                        <div id="d-email-row" class="flex items-center gap-1.5">
                          <i data-lucide="mail" class="w-3 h-3 shrink-0"></i>
                          <span id="d-email">email@company.com</span>
                        </div>
                        <div id="d-phone-row" class="flex items-center gap-1.5">
                          <i data-lucide="phone" class="w-3 h-3 shrink-0"></i>
                          <span id="d-phone">+1 (555) 000-0000</span>
                        </div>
                        <div id="d-website-row" class="flex items-center gap-1.5">
                          <i data-lucide="globe" class="w-3 h-3 shrink-0"></i>
                          <span id="d-website">www.company.com</span>
                        </div>
                        <div id="d-address-row" class="flex items-center gap-1.5">
                          <i data-lucide="map-pin" class="w-3 h-3 shrink-0"></i>
                          <span id="d-address"></span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Branded style -->
                <div id="style-branded" class="card-style absolute inset-0 hidden flex flex-col justify-between p-7"
                  style="background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);">
                  <div>
                    <div id="b-name" class="text-xl font-bold text-white leading-tight">Your Name</div>
                    <div id="b-title" class="text-sm text-white/70 mt-0.5">Job Title</div>
                  </div>
                  <div>
                    <div id="b-company" class="text-base font-semibold text-white mb-3">Company Name</div>
                    <div class="space-y-1.5 text-xs text-white/80">
                      <div id="b-email-row" class="flex items-center gap-1.5">
                        <i data-lucide="mail" class="w-3 h-3 shrink-0"></i>
                        <span id="b-email">email@company.com</span>
                      </div>
                      <div id="b-phone-row" class="flex items-center gap-1.5">
                        <i data-lucide="phone" class="w-3 h-3 shrink-0"></i>
                        <span id="b-phone">+1 (555) 000-0000</span>
                      </div>
                      <div id="b-website-row" class="flex items-center gap-1.5">
                        <i data-lucide="globe" class="w-3 h-3 shrink-0"></i>
                        <span id="b-website">www.company.com</span>
                      </div>
                      <div id="b-address-row" class="flex items-center gap-1.5">
                        <i data-lucide="map-pin" class="w-3 h-3 shrink-0"></i>
                        <span id="b-address"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <p class="text-xs text-gray-400 mt-3 text-center">Preview is approximate — final design may vary slightly</p>
          </div>

          <!-- Order summary -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <h3 class="text-sm font-semibold text-gray-700 mb-4">Order Summary</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-gray-400">Quantity</dt>
                <dd id="summary-qty" class="font-medium text-gray-900">500 cards</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-400">Style</dt>
                <dd id="summary-style" class="font-medium text-gray-900 capitalize">Classic</dd>
              </div>
            </dl>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    // ── Auth + pre-populate from clients.json ──
    const CLIENT_DATA = JSON.parse(document.getElementById('client-data').textContent);

    let currentUser = null;

    const FIELD_ROWS = {
      name:      'row-name',
      title:     'row-name',
      email:     'row-email',
      phone:     'row-phone-ext-cell',
      extension: 'row-phone-ext-cell',
      cell:      'row-phone-ext-cell',
      website:   'row-website-address',
      address:   'row-website-address',
    };

    function prefill(email) {
      const data = CLIENT_DATA[email] || {};
      const allowedFields = data.fields || ['name','title','email','phone','extension','cell','website','address'];
      const lockedFields  = data.locked || [];

      const set = (id, val) => {
        const el = document.getElementById(id);
        if (!el) return;
        if (val !== undefined && val !== null) {
          el.value = val;
          el.dispatchEvent(new Event('input'));
        }
        const fieldKey = id.replace('f-', '');
        if (lockedFields.includes(fieldKey)) {
          el.readOnly = true;
          el.classList.add('bg-gray-50', 'text-gray-500', 'cursor-not-allowed');
        }
      };

      set('f-name',      data.full_name  || '');
      set('f-title',     data.job_title  || '');
      set('f-company',   data.company    || '');
      set('f-email',     data.email      || email || '');
      set('f-phone',     data.phone      || '');
      set('f-extension', data.extension  || '');
      set('f-cell',      data.cell       || '');
      set('f-address',   data.address    || '');
      set('f-website',   data.website    || '');

      const visibleRows = new Set(allowedFields.map(f => FIELD_ROWS[f]).filter(Boolean));
      document.querySelectorAll('[data-field-row]').forEach(row => {
        row.style.display = visibleRows.has(row.id) ? '' : 'none';
      });
    }

    function getInitials(name, email) {
      if (name && name.trim()) {
        return name.trim().split(/\s+/).map(w => w[0]).join('').toUpperCase().slice(0, 2);
      }
      return (email || '?')[0].toUpperCase();
    }

    function initUser(user) {
      if (!user) { window.location.href = '/'; return; }
      currentUser = user;
      const data = CLIENT_DATA[user.email] || {};

      const displayName = data.full_name || user.user_metadata?.full_name || '';
      const initials = getInitials(displayName, user.email);

      document.getElementById('user-initials').textContent = initials;
      document.getElementById('nav-name').textContent      = displayName || user.email;
      document.getElementById('dd-name').textContent       = displayName || user.email;
      document.getElementById('dd-email').textContent      = user.email;

      prefill(user.email);
    }

    function getUserFromStorage() {
      try { return JSON.parse(localStorage.getItem('gotrue.user') || 'null'); } catch { return null; }
    }

    document.addEventListener('DOMContentLoaded', () => {
      // Render Lucide icons
      if (window.lucide) window.lucide.createIcons();

      // Auth init
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => initUser(user || getUserFromStorage()));
      } else {
        initUser(getUserFromStorage());
      }

      // ── User dropdown ──
      const menuBtn  = document.getElementById('user-menu-btn');
      const dropdown = document.getElementById('user-dropdown');

      menuBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown?.classList.toggle('hidden');
      });
      document.addEventListener('click', () => dropdown?.classList.add('hidden'));
      dropdown?.addEventListener('click', (e) => e.stopPropagation());

      document.getElementById('dd-edit-btn')?.addEventListener('click', () => {
        dropdown?.classList.add('hidden');
        const nameField = document.getElementById('f-name');
        if (nameField) {
          nameField.scrollIntoView({ behavior: 'smooth', block: 'center' });
          setTimeout(() => nameField.focus(), 300);
        }
      });

      document.getElementById('nav-logout')?.addEventListener('click', () => {
        localStorage.removeItem('gotrue.user');
        window.netlifyIdentity?.logout();
        window.location.href = '/';
      });

      // ── Refresh / reset ──
      document.getElementById('refresh-btn')?.addEventListener('click', () => {
        if (!currentUser) return;
        const notesEl = document.getElementById('f-notes');
        if (notesEl) notesEl.value = '';
        prefill(currentUser.email);
        const btn = document.getElementById('refresh-btn');
        btn.classList.add('text-green-600');
        setTimeout(() => btn.classList.remove('text-green-600'), 800);
      });
    });
  </script>

  <script>
    // ── Live Preview ──
    const fields = {
      name:    document.getElementById('f-name'),
      title:   document.getElementById('f-title'),
      company: document.getElementById('f-company'),
      email:   document.getElementById('f-email'),
      phone:   document.getElementById('f-phone'),
      website: document.getElementById('f-website'),
      address: document.getElementById('f-address'),
      accent:  document.getElementById('f-accent'),
      qty:     document.getElementById('f-qty'),
    };

    const placeholders = {
      name:    'Your Name',
      title:   'Job Title',
      company: 'Company Name',
      email:   'email@company.com',
      phone:   '+1 (555) 000-0000',
      website: 'www.company.com',
      address: '',
    };

    let currentStyle = 'classic';

    function updatePreview() {
      const vals = {
        name:    fields.name?.value    || placeholders.name,
        title:   fields.title?.value   || placeholders.title,
        company: fields.company?.value || placeholders.company,
        email:   fields.email?.value   || placeholders.email,
        phone:   fields.phone?.value   || placeholders.phone,
        website: fields.website?.value || placeholders.website,
        address: fields.address?.value || '',
      };

      ['c','d','b'].forEach(prefix => {
        const set  = (id, val)     => { const el = document.getElementById(id); if (el) el.textContent = val; };
        const show = (id, visible) => { const el = document.getElementById(id); if (el) el.style.display = visible ? '' : 'none'; };

        set(`${prefix}-name`,    vals.name);
        set(`${prefix}-title`,   vals.title);
        set(`${prefix}-company`, vals.company);
        set(`${prefix}-email`,   vals.email);
        set(`${prefix}-phone`,   vals.phone);
        set(`${prefix}-website`, vals.website);
        set(`${prefix}-address`, vals.address);
        show(`${prefix}-website-row`, !!vals.website);
        show(`${prefix}-address-row`, !!vals.address);
      });

      const summaryQty   = document.getElementById('summary-qty');
      const summaryStyle = document.getElementById('summary-style');
      if (summaryQty)   summaryQty.textContent   = `${Number(fields.qty?.value || 500).toLocaleString()} cards`;
      if (summaryStyle) summaryStyle.textContent = currentStyle.charAt(0).toUpperCase() + currentStyle.slice(1);
    }

    function switchStyle(style) {
      currentStyle = style;
      const styleInput = document.getElementById('f-style');
      if (styleInput) styleInput.value = style;

      document.querySelectorAll('.style-btn').forEach(btn => {
        const isActive = btn.dataset.style === style;
        btn.classList.toggle('border-sky-500', isActive);
        btn.classList.toggle('bg-sky-50', isActive);
        btn.classList.toggle('border-gray-200', !isActive);
      });

      ['classic','dark','branded'].forEach(s => {
        const el = document.getElementById(`style-${s}`);
        if (el) el.classList.toggle('hidden', s !== style);
      });

      const accentRow = document.getElementById('accent-color-row');
      if (accentRow) accentRow.classList.toggle('hidden', style !== 'branded');

      updatePreview();
    }

    function updateBrandedColor(hex) {
      const branded = document.getElementById('style-branded');
      if (branded) branded.style.background = `linear-gradient(135deg, ${hex} 0%, ${shadeColor(hex, -40)} 100%)`;
    }

    function shadeColor(hex, percent) {
      const num = parseInt(hex.replace('#',''), 16);
      const r = Math.min(255, Math.max(0, (num >> 16) + percent));
      const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + percent));
      const b = Math.min(255, Math.max(0, (num & 0x0000FF) + percent));
      return '#' + (0x1000000 + r * 0x10000 + g * 0x100 + b).toString(16).slice(1);
    }

    Object.values(fields).forEach(el => {
      if (el) el.addEventListener('input', updatePreview);
    });

    document.getElementById('style-picker')?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-style]');
      if (btn) switchStyle(btn.dataset.style);
    });

    fields.accent?.addEventListener('input', (e) => updateBrandedColor(e.target.value));

    updatePreview();
  </script>

  <script>
    // ── Form submission to Netlify Forms ──
    document.getElementById('order-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn     = document.getElementById('submit-btn');
      const submitText    = document.getElementById('submit-text');
      const submitLoading = document.getElementById('submit-loading');
      const errorDiv      = document.getElementById('form-error');

      const required = ['f-name','f-title','f-email'];
      const missing  = required.filter(id => !document.getElementById(id)?.value.trim());
      if (missing.length) {
        errorDiv.textContent = 'Please fill in all required fields.';
        errorDiv.classList.remove('hidden');
        return;
      }
      errorDiv.classList.add('hidden');

      const storedUser = (() => { try { return JSON.parse(localStorage.getItem('gotrue.user') || '{}'); } catch { return {}; } })();
      const user = window.netlifyIdentity?.currentUser?.();
      const orderedBy = user?.email || storedUser.email || 'unknown';

      const data = new FormData();
      data.append('form-name',    'business-card-order');
      data.append('name',         document.getElementById('f-name')?.value      || '');
      data.append('job_title',    document.getElementById('f-title')?.value     || '');
      data.append('company',      document.getElementById('f-company')?.value   || '');
      data.append('email',        document.getElementById('f-email')?.value     || '');
      data.append('phone',        document.getElementById('f-phone')?.value     || '');
      data.append('extension',    document.getElementById('f-extension')?.value || '');
      data.append('cell',         document.getElementById('f-cell')?.value      || '');
      data.append('address',      document.getElementById('f-address')?.value   || '');
      data.append('card_style',   document.getElementById('f-style')?.value     || 'classic');
      data.append('accent_color', document.getElementById('f-accent')?.value    || '');
      data.append('quantity',     document.getElementById('f-qty')?.value       || '500');
      data.append('notes',        document.getElementById('f-notes')?.value     || '');
      data.append('ordered_by',   orderedBy);

      submitBtn.disabled = true;
      submitText.classList.add('hidden');
      submitLoading.classList.remove('hidden');

      try {
        const response = await fetch('/', { method: 'POST', body: data });
        if (response.ok) {
          window.location.href = '/success';
        } else {
          throw new Error(`Server returned ${response.status}`);
        }
      } catch (err) {
        errorDiv.textContent = 'Something went wrong. Please try again or contact us directly.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitText.classList.remove('hidden');
        submitLoading.classList.add('hidden');
      }
    });
  </script>
</Layout>
