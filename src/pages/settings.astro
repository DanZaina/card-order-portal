---
import Layout from '../layouts/Layout.astro';
import clients from '../data/clients.json';
const clientsJson = JSON.stringify(clients);
---
<Layout title="Settings — Card Order Portal">
  <script id="client-data" type="application/json" set:html={clientsJson}></script>

  <style is:global>
    :root { --ta: #1e293b; --ta-h: #0f172a; --sidebar-bg: #1e293b; }
    #user-avatar  { background-color: var(--ta) !important; }
    #sidebar, #mobile-sidebar-panel { background-color: var(--sidebar-bg); }
    #mobile-topbar { background-color: var(--sidebar-bg); }
    .sidebar-nav-active { background-color: rgba(255,255,255,0.12) !important; }
    .sidebar-nav-item:hover { background-color: rgba(255,255,255,0.08); }
    button svg, a svg { display: block; }
  </style>

  <div class="flex h-screen overflow-hidden bg-gray-50">

    <!-- ── Sidebar (desktop) ── -->
    <div class="hidden lg:flex lg:w-64 lg:flex-col lg:fixed lg:inset-y-0 z-30">
      <div id="sidebar" class="flex grow flex-col overflow-y-auto pb-4">
        <div class="flex h-16 shrink-0 items-center px-6">
          <img src="/logo-landscape-white.png" alt="ION Professional Printing" class="h-7 object-contain" />
        </div>
        <nav class="flex flex-1 flex-col px-6">
          <ul role="list" class="flex flex-1 flex-col gap-y-7">
            <li>
              <ul role="list" class="-mx-2 space-y-1">
                <li>
                  <a href="/order"
                    class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
                    <i data-lucide="credit-card" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
                    Order Cards
                  </a>
                </li>
                <li>
                  <a href="/history"
                    class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
                    <i data-lucide="clock" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
                    Order History
                  </a>
                </li>
                <li>
                  <a href="/settings"
                    class="sidebar-nav-item sidebar-nav-active group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white">
                    <i data-lucide="settings" class="w-6 h-6 shrink-0 text-white"></i>
                    Settings
                  </a>
                </li>
              </ul>
            </li>
            <li class="-mx-6 mt-auto border-t border-white/10 pt-1 relative">
              <!-- Flyout menu (opens upward) -->
              <div id="user-flyout" class="hidden absolute bottom-full left-2 right-2 mb-1 bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden z-50">
                <a href="/account"
                  class="flex items-center gap-x-3 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                  <i data-lucide="user" class="w-4 h-4 text-gray-400 shrink-0"></i>
                  My Account
                </a>
                <a href="/settings"
                  class="flex items-center gap-x-3 px-4 py-3 text-sm text-gray-700 bg-gray-50 font-medium transition-colors">
                  <i data-lucide="settings" class="w-4 h-4 text-gray-400 shrink-0"></i>
                  Settings
                </a>
                <div class="border-t border-gray-100"></div>
                <button id="nav-logout" type="button"
                  class="w-full flex items-center gap-x-3 px-4 py-3 text-sm text-red-500 hover:bg-red-50 transition-colors">
                  <i data-lucide="log-out" class="w-4 h-4 shrink-0"></i>
                  Sign out
                </button>
              </div>
              <!-- Trigger button -->
              <button id="user-menu-btn" type="button"
                class="w-full flex items-center gap-x-3 px-6 py-3 hover:bg-white/5 transition-colors">
                <div id="user-avatar"
                  class="w-9 h-9 rounded-full text-white flex items-center justify-center text-xs font-bold shrink-0 select-none">
                  <span id="user-initials">?</span>
                </div>
                <div class="min-w-0 flex-1 text-left">
                  <p id="dd-client-name" class="text-sm font-semibold text-white truncate"></p>
                  <p id="dd-email" class="text-xs text-white/50 truncate"></p>
                </div>
                <i data-lucide="chevrons-up-down" class="w-4 h-4 text-white/40 shrink-0"></i>
              </button>
              <span id="dd-name" class="hidden"></span>
            </li>
          </ul>
        </nav>
      </div>
    </div>

    <!-- ── Mobile top bar ── -->
    <div id="mobile-topbar" class="lg:hidden fixed top-0 left-0 right-0 z-20 flex items-center gap-x-4 px-4 py-3 shadow-sm">
      <button id="mobile-menu-btn" type="button" class="text-white">
        <i data-lucide="menu" class="w-6 h-6"></i>
      </button>
      <img src="/logo-landscape-white.png" alt="ION" class="h-7 object-contain" />
    </div>

    <!-- ── Mobile sidebar overlay ── -->
    <div id="mobile-sidebar-overlay" class="hidden fixed inset-0 z-40 lg:hidden">
      <div id="sidebar-backdrop" class="fixed inset-0 bg-gray-900/80"></div>
      <div id="mobile-sidebar-panel" class="fixed inset-y-0 left-0 flex w-64 flex-col">
        <div class="flex grow flex-col overflow-y-auto pb-4">
          <div class="flex h-16 shrink-0 items-center justify-between px-6">
            <img src="/logo-landscape-white.png" class="h-7 object-contain" />
            <button id="mobile-sidebar-close" type="button" class="text-white/70 hover:text-white">
              <i data-lucide="x" class="w-5 h-5"></i>
            </button>
          </div>
          <nav class="flex flex-col px-6 gap-y-1">
            <a href="/order"
              class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="credit-card" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Order Cards
            </a>
            <a href="/history"
              class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="clock" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Order History
            </a>
            <a href="/settings"
              class="sidebar-nav-item sidebar-nav-active group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white">
              <i data-lucide="settings" class="w-6 h-6 shrink-0 text-white"></i>
              Settings
            </a>
            <a href="/account"
              class="sidebar-nav-item group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="user" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              My Account
            </a>
            <button type="button" id="mobile-nav-logout"
              class="sidebar-nav-item w-full group flex gap-x-3 rounded-md p-2 text-sm font-semibold text-white/70 hover:text-white transition-colors">
              <i data-lucide="log-out" class="w-6 h-6 shrink-0 text-white/70 group-hover:text-white"></i>
              Sign out
            </button>
          </nav>
        </div>
      </div>
    </div>

    <!-- ── Main content ── -->
    <div class="flex flex-1 flex-col lg:pl-64">
      <main class="flex-1 overflow-y-auto">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 pt-16 lg:pt-10">

          <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-900">Settings</h1>
            <p class="text-gray-400 mt-1 text-sm">Manage your portal preferences</p>
          </div>

          <!-- Notification preferences -->
          <div class="bg-white rounded-2xl border border-gray-200 divide-y divide-gray-100">

            <div class="px-6 py-5">
              <h2 class="text-sm font-semibold text-gray-700 mb-4">Notifications</h2>
              <div class="space-y-4">
                <label class="flex items-center justify-between gap-4 cursor-pointer">
                  <div>
                    <p class="text-sm font-medium text-gray-800">Order confirmations</p>
                    <p class="text-xs text-gray-400 mt-0.5">Receive an email when your order is received</p>
                  </div>
                  <div class="relative shrink-0">
                    <input id="notif-confirm" type="checkbox" class="sr-only peer" checked />
                    <div class="w-10 h-6 rounded-full bg-gray-200 peer-checked:bg-gray-900 transition-colors"></div>
                    <div class="absolute top-1 left-1 w-4 h-4 rounded-full bg-white shadow transition-transform peer-checked:translate-x-4"></div>
                  </div>
                </label>
                <label class="flex items-center justify-between gap-4 cursor-pointer">
                  <div>
                    <p class="text-sm font-medium text-gray-800">Proof ready alerts</p>
                    <p class="text-xs text-gray-400 mt-0.5">Get notified when your card proof is ready to review</p>
                  </div>
                  <div class="relative shrink-0">
                    <input id="notif-proof" type="checkbox" class="sr-only peer" checked />
                    <div class="w-10 h-6 rounded-full bg-gray-200 peer-checked:bg-gray-900 transition-colors"></div>
                    <div class="absolute top-1 left-1 w-4 h-4 rounded-full bg-white shadow transition-transform peer-checked:translate-x-4"></div>
                  </div>
                </label>
              </div>
            </div>

            <div class="px-6 py-5">
              <h2 class="text-sm font-semibold text-gray-700 mb-4">Default Order</h2>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5" for="default-qty">Default quantity</label>
                  <div class="relative max-w-xs">
                    <select id="default-qty"
                      class="w-full px-4 py-3 pr-10 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm bg-white appearance-none">
                      <option value="250">250 cards</option>
                      <option value="500" selected>500 cards</option>
                      <option value="1000">1,000 cards</option>
                      <option value="2000">2,000 cards</option>
                      <option value="5000">5,000 cards</option>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                      <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="px-6 py-5 flex justify-end">
              <button id="settings-save"
                class="px-5 py-2.5 rounded-xl bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium transition-colors">
                Save Settings
              </button>
            </div>
          </div>

          <!-- Danger zone -->
          <div class="mt-8 bg-white rounded-2xl border border-red-100">
            <div class="px-6 py-5">
              <h2 class="text-sm font-semibold text-red-600 mb-1">Danger Zone</h2>
              <p class="text-xs text-gray-400 mb-4">These actions cannot be undone</p>
              <button id="clear-history-btn"
                class="px-4 py-2.5 rounded-xl border border-red-200 text-sm text-red-600 hover:bg-red-50 transition-colors">
                Clear order history
              </button>
            </div>
          </div>

        </div>
      </main>
    </div>
  </div>

  <!-- ── Account modal ── -->
  <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 overflow-y-auto" style="max-height: 90vh;">
      <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-gray-100">
        <h3 class="text-base font-semibold text-gray-900">My Account</h3>
        <button id="edit-modal-close" class="text-gray-400 hover:text-gray-600 transition-colors">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      <div class="px-6 py-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="acct-email">Email</label>
          <input id="acct-email" type="email" readonly
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-400 text-sm cursor-not-allowed outline-none" />
          <p class="text-xs text-gray-400 mt-1">Managed by your administrator</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="edit-display-name">Full Name</label>
          <input id="edit-display-name" type="text" placeholder="Your name"
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="acct-phone">Phone</label>
          <input id="acct-phone" type="tel" placeholder="(000) 000-0000"
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-slate-500 focus:ring-2 focus:ring-slate-200 outline-none transition text-sm" />
        </div>
        <div class="flex gap-3 pt-2">
          <button id="edit-modal-cancel"
            class="flex-1 py-2.5 px-4 rounded-xl border border-gray-200 text-sm text-gray-600 hover:bg-gray-50 transition-colors">
            Cancel
          </button>
          <button id="edit-modal-save"
            class="flex-1 py-2.5 px-4 rounded-xl bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium transition-colors">
            Save
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const CLIENT_DATA = JSON.parse(document.getElementById('client-data').textContent);
    let currentUser = null;

    function applyClientTheme(theme) {
      if (!theme) return;
      if (theme.accent)    document.documentElement.style.setProperty('--ta',         theme.accent);
      if (theme.dark)      document.documentElement.style.setProperty('--ta-h',       theme.dark);
      if (theme.sidebarBg) document.documentElement.style.setProperty('--sidebar-bg', theme.sidebarBg);
    }

    function getInitials(name, email) {
      if (name && name.trim())
        return name.trim().split(/\s+/).map(w => w[0]).join('').toUpperCase().slice(0, 2);
      return (email || '?')[0].toUpperCase();
    }

    function initUser(user) {
      if (!user) { window.location.href = '/'; return; }
      currentUser = user;
      const data = CLIENT_DATA[user.email] || {};
      const savedName   = localStorage.getItem('portal.displayName');
      const displayName = savedName || data.full_name || user.user_metadata?.full_name || '';

      document.getElementById('user-initials').textContent = getInitials(displayName, user.email);
      document.getElementById('dd-email').textContent      = user.email;
      const clientEl = document.getElementById('dd-client-name');
      if (clientEl) clientEl.textContent = data.company || displayName || user.email || '';

      if (data.theme) applyClientTheme(data.theme);

      // Restore settings
      const savedQty = localStorage.getItem('portal.defaultQty');
      if (savedQty) (document.getElementById('default-qty') as HTMLSelectElement).value = savedQty;
      const notifConfirm = localStorage.getItem('portal.notifConfirm');
      if (notifConfirm !== null) (document.getElementById('notif-confirm') as HTMLInputElement).checked = notifConfirm === 'true';
      const notifProof = localStorage.getItem('portal.notifProof');
      if (notifProof !== null) (document.getElementById('notif-proof') as HTMLInputElement).checked = notifProof === 'true';
    }

    function getUserFromStorage() {
      try { return JSON.parse(localStorage.getItem('gotrue.user') || 'null'); } catch { return null; }
    }

    document.addEventListener('DOMContentLoaded', () => {
      if (window.lucide) window.lucide.createIcons();

      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => initUser(user || getUserFromStorage()));
      } else {
        initUser(getUserFromStorage());
      }

      // Mobile sidebar
      const mobileOverlay      = document.getElementById('mobile-sidebar-overlay');
      const openMobileSidebar  = () => mobileOverlay?.classList.remove('hidden');
      const closeMobileSidebar = () => mobileOverlay?.classList.add('hidden');
      document.getElementById('mobile-menu-btn')?.addEventListener('click', openMobileSidebar);
      document.getElementById('mobile-sidebar-close')?.addEventListener('click', closeMobileSidebar);
      document.getElementById('sidebar-backdrop')?.addEventListener('click', closeMobileSidebar);

      // User flyout
      const userFlyout  = document.getElementById('user-flyout');
      const userMenuBtn = document.getElementById('user-menu-btn');
      userMenuBtn?.addEventListener('click', (e) => { e.stopPropagation(); userFlyout?.classList.toggle('hidden'); });
      document.addEventListener('click', () => userFlyout?.classList.add('hidden'));
      userFlyout?.addEventListener('click', (e) => e.stopPropagation());

      // Account modal
      const editModal = document.getElementById('edit-modal');
      const openEditModal = () => {
        closeMobileSidebar();
        userFlyout?.classList.add('hidden');
        const saved = localStorage.getItem('portal.displayName')
          || (currentUser ? (CLIENT_DATA[currentUser.email]?.full_name || '') : '');
        (document.getElementById('edit-display-name') as HTMLInputElement).value = saved;
        (document.getElementById('acct-email') as HTMLInputElement).value = currentUser?.email || '';
        (document.getElementById('acct-phone') as HTMLInputElement).value =
          localStorage.getItem('portal.phone') || (currentUser ? (CLIENT_DATA[currentUser.email]?.phone || '') : '');
        editModal?.classList.remove('hidden');
        setTimeout(() => document.getElementById('edit-display-name')?.focus(), 50);
      };
      const closeModal = () => editModal?.classList.add('hidden');
      document.getElementById('nav-account-btn')?.addEventListener('click', openEditModal);
      document.getElementById('mobile-nav-account-btn')?.addEventListener('click', openEditModal);
      document.getElementById('edit-modal-close')?.addEventListener('click', closeModal);
      document.getElementById('edit-modal-cancel')?.addEventListener('click', closeModal);
      editModal?.addEventListener('click', (e) => { if (e.target === editModal) closeModal(); });
      document.getElementById('edit-modal-save')?.addEventListener('click', () => {
        const name  = (document.getElementById('edit-display-name') as HTMLInputElement).value.trim();
        const phone = (document.getElementById('acct-phone') as HTMLInputElement).value.trim();
        if (name) localStorage.setItem('portal.displayName', name);
        if (phone) localStorage.setItem('portal.phone', phone);
        closeModal();
      });

      // Logout
      const doLogout = () => {
        localStorage.removeItem('gotrue.user');
        localStorage.removeItem('portal.displayName');
        window.netlifyIdentity?.logout();
        window.location.href = '/';
      };
      document.getElementById('nav-logout')?.addEventListener('click', doLogout);
      document.getElementById('mobile-nav-logout')?.addEventListener('click', doLogout);

      // Settings save
      document.getElementById('settings-save')?.addEventListener('click', () => {
        const qty = (document.getElementById('default-qty') as HTMLSelectElement).value;
        const notifConfirm = (document.getElementById('notif-confirm') as HTMLInputElement).checked;
        const notifProof   = (document.getElementById('notif-proof') as HTMLInputElement).checked;
        localStorage.setItem('portal.defaultQty',     qty);
        localStorage.setItem('portal.notifConfirm',   String(notifConfirm));
        localStorage.setItem('portal.notifProof',     String(notifProof));
        const btn = document.getElementById('settings-save');
        if (btn) { btn.textContent = 'Saved!'; setTimeout(() => btn.textContent = 'Save Settings', 1500); }
      });

      // Clear history
      document.getElementById('clear-history-btn')?.addEventListener('click', () => {
        if (confirm('Clear all order history? This cannot be undone.')) {
          localStorage.removeItem('portal.orders');
          const btn = document.getElementById('clear-history-btn');
          if (btn) { btn.textContent = 'History cleared'; btn.disabled = true; }
        }
      });
    });
  </script>
</Layout>
