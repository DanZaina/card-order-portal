---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Order Submitted — Card Order Portal">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <div class="max-w-md w-full text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 mb-6">
        <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 mb-3">Order Submitted!</h1>
      <p class="text-gray-500 mb-8">
        Your business card order has been received. We'll review the details and be in touch shortly to confirm your order and discuss any final adjustments.
      </p>

      <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 text-left">
        <h2 class="text-sm font-semibold text-gray-700 mb-3">What happens next?</h2>
        <ol class="space-y-3">
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-slate-900 text-white text-xs flex items-center justify-center font-semibold">1</span>
            <p class="text-sm text-gray-600">We review your card details and contact you to confirm the design.</p>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-slate-900 text-white text-xs flex items-center justify-center font-semibold">2</span>
            <p class="text-sm text-gray-600">A proof is sent for your approval before printing begins.</p>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-slate-900 text-white text-xs flex items-center justify-center font-semibold">3</span>
            <p class="text-sm text-gray-600">Cards are printed and delivered to you.</p>
          </li>
        </ol>
      </div>

      <a href="/order"
        class="inline-block py-3 px-8 bg-slate-900 hover:bg-slate-700 text-white font-semibold rounded-xl transition-colors duration-200">
        Place Another Order
      </a>
    </div>
  </div>
</Layout>
